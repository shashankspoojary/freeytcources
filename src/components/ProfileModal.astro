---
---

<!-- Global User Profile Modal Component -->
<div 
  id="user-profile-modal" 
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-300 hidden"
>
  <div id="user-profile-card" class="bg-canvas border border-hairline rounded-md p-6 max-w-sm w-full mx-4 shadow-2xl space-y-6 transform scale-95 transition-all duration-300">
    
    <!-- Modal Header -->
    <div class="flex items-center justify-between border-b border-hairline pb-4">
      <div class="flex items-center gap-2">
        <span class="inline-block font-mono text-[10px] text-primary uppercase tracking-widest bg-primary/10 px-2.5 py-0.5 rounded-pill border border-primary/20 font-semibold">
          User Account Profile
        </span>
      </div>
      <button 
        id="close-profile-modal-btn" 
        type="button" 
        class="text-mute hover:text-ink transition-colors p-1 rounded-sm cursor-pointer border-none bg-transparent"
        aria-label="Close Profile Modal"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- User Details Section -->
    <div class="flex items-center gap-4 bg-canvas-soft/60 border border-hairline p-4 rounded-sm">
      <div id="profile-modal-avatar-container" class="h-12 w-12 rounded-full bg-primary/10 border border-primary/30 text-primary font-bold text-lg flex items-center justify-center shrink-0 overflow-hidden">
        <span id="profile-modal-initials">U</span>
        <img id="profile-modal-photo" src="" alt="Profile Photo" class="h-full w-full object-cover hidden" />
      </div>
      <div class="truncate flex-1">
        <div class="flex items-center gap-2">
          <h3 id="profile-modal-name" class="text-sm font-bold text-ink-strong truncate">Learner</h3>
          <span id="profile-modal-provider-badge" class="text-[9px] font-mono uppercase bg-canvas border border-hairline text-primary px-1.5 py-0.5 rounded-xs font-semibold shrink-0">Local</span>
        </div>
        <p id="profile-modal-email" class="text-xs font-mono text-mute truncate mt-0.5">user@example.com</p>
      </div>
    </div>

    <!-- Edit Display Name Section -->
    <div class="space-y-2">
      <div class="flex justify-between items-center text-xs font-mono">
        <span class="text-mute font-semibold">Display Name</span>
        <button id="toggle-edit-name-btn" type="button" class="text-primary hover:underline text-[11px] cursor-pointer bg-transparent border-none">Edit Name</button>
      </div>
      <div id="edit-name-form-row" class="hidden flex gap-2">
        <input 
          type="text" 
          id="profile-name-input" 
          class="flex-1 bg-canvas border border-hairline text-ink rounded-sm px-3 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" 
          placeholder="Enter new display name..."
        />
        <button id="save-name-btn" type="button" class="bg-primary text-on-primary font-mono text-xs font-bold px-3 py-1.5 rounded-sm hover:bg-primary-soft cursor-pointer">Save</button>
      </div>
    </div>

    <!-- Quick Navigation Links -->
    <div class="space-y-1 pt-1 border-t border-hairline/50">
      <a href="/watch-later" class="flex items-center justify-between px-3 py-2 text-xs font-mono text-body hover:text-ink hover:bg-canvas-soft rounded-sm transition-colors">
        <div class="flex items-center gap-2.5">
          <svg class="h-4 w-4 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Watch Later Playlist</span>
        </div>
        <svg class="h-3.5 w-3.5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>

      <a href="/subscriptions" class="flex items-center justify-between px-3 py-2 text-xs font-mono text-body hover:text-ink hover:bg-canvas-soft rounded-sm transition-colors">
        <div class="flex items-center gap-2.5">
          <svg class="h-4 w-4 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <span>Subscriptions</span>
        </div>
        <svg class="h-3.5 w-3.5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Actions Footer -->
    <div class="flex justify-end items-center pt-3 border-t border-hairline/60">
      <button 
        id="profile-logout-btn" 
        type="button" 
        class="bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/30 px-4 py-2 rounded-sm text-xs font-mono uppercase font-bold transition-all cursor-pointer flex items-center gap-1.5 shadow-sm"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        Log Out
      </button>
    </div>
  </div>
</div>

<script>
  function initProfileModal() {
    const modal = document.getElementById('user-profile-modal');
    const card = document.getElementById('user-profile-card');
    const closeBtn = document.getElementById('close-profile-modal-btn');
    const logoutBtn = document.getElementById('profile-logout-btn');
    
    const nameEl = document.getElementById('profile-modal-name');
    const emailEl = document.getElementById('profile-modal-email');
    const initialsEl = document.getElementById('profile-modal-initials');
    const photoEl = document.getElementById('profile-modal-photo') as HTMLImageElement;
    const providerBadge = document.getElementById('profile-modal-provider-badge');

    const toggleEditBtn = document.getElementById('toggle-edit-name-btn');
    const editRow = document.getElementById('edit-name-form-row');
    const nameInput = document.getElementById('profile-name-input') as HTMLInputElement;
    const saveNameBtn = document.getElementById('save-name-btn');

    function getUserSession() {
      try {
        const raw = localStorage.getItem('freeyt_user_auth');
        return raw ? JSON.parse(raw) : null;
      } catch (e) {
        return null;
      }
    }

    function openModal() {
      const user = getUserSession();
      if (!user) {
        window.location.href = '/login';
        return;
      }

      if (nameEl) nameEl.textContent = user.displayName || 'Learner';
      if (emailEl) emailEl.textContent = user.email || 'user@example.com';
      if (nameInput) nameInput.value = user.displayName || '';

      const firstInitial = (user.displayName || user.email || 'U').charAt(0).toUpperCase();
      if (initialsEl) initialsEl.textContent = firstInitial;

      if (user.photoURL && photoEl) {
        photoEl.src = user.photoURL;
        photoEl.classList.remove('hidden');
        if (initialsEl) initialsEl.classList.add('hidden');
      } else {
        if (photoEl) photoEl.classList.add('hidden');
        if (initialsEl) initialsEl.classList.remove('hidden');
      }

      if (providerBadge) {
        const prov = (user.provider || 'local').replace('.com', '');
        providerBadge.textContent = prov;
      }

      if (modal && card) {
        modal.classList.remove('hidden');
        setTimeout(() => {
          modal.classList.remove('opacity-0', 'pointer-events-none');
          modal.classList.add('opacity-100', 'pointer-events-auto');
          card.classList.remove('scale-95');
          card.classList.add('scale-100');
        }, 50);
      }
    }

    function closeModal() {
      if (!modal || !card) return;
      modal.classList.remove('opacity-100', 'pointer-events-auto');
      modal.classList.add('opacity-0', 'pointer-events-none');
      card.classList.remove('scale-100');
      card.classList.add('scale-95');
      setTimeout(() => {
        modal.classList.add('hidden');
        if (editRow) editRow.classList.add('hidden');
      }, 300);
    }

    closeBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    toggleEditBtn?.addEventListener('click', () => {
      if (editRow) editRow.classList.toggle('hidden');
    });

    saveNameBtn?.addEventListener('click', () => {
      const newName = nameInput?.value.trim();
      if (!newName) return;
      const user = getUserSession();
      if (user) {
        user.displayName = newName;
        localStorage.setItem('freeyt_user_auth', JSON.stringify(user));
        if (nameEl) nameEl.textContent = newName;
        if (editRow) editRow.classList.add('hidden');
        window.dispatchEvent(new CustomEvent('userAuthChanged', { detail: user }));
      }
    });

    logoutBtn?.addEventListener('click', () => {
      localStorage.removeItem('freeyt_user_auth');
      window.dispatchEvent(new CustomEvent('userAuthChanged', { detail: null }));
      closeModal();
      window.location.reload();
    });

    // Handle any elements triggering profile open
    document.querySelectorAll('[data-open-profile="true"]').forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        openModal();
      });
    });

    window.addEventListener('openUserProfileModal', openModal);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProfileModal);
  } else {
    initProfileModal();
  }
</script>
