---
import { getAllCourses, getCreatorSlug } from '../lib/firebase.js';

interface Props {
  activePage?: string;
}

const { activePage = 'home' } = Astro.props;

const courses = await getAllCourses();

// Extract unique creators for YouTube sidebar subscription list
const uniqueCreatorsMap = new Map();
courses.forEach(c => {
  const slug = getCreatorSlug(c.creatorName);
  if (!uniqueCreatorsMap.has(slug)) {
    uniqueCreatorsMap.set(slug, {
      name: c.creatorName,
      slug: slug,
      logo: c.creatorLogo,
      subscribers: c.creatorSubscribers || "1.5M subscribers"
    });
  }
});
const creatorsList = Array.from(uniqueCreatorsMap.values());
---

<!-- Mobile Drawer Backdrop Overlay -->
<div id="sidebar-backdrop" class="fixed inset-0 bg-black/60 z-30 hidden transition-opacity"></div>

<!-- Main YouTube-Style Collapsible Sidebar -->
<aside id="yt-sidebar" class="fixed top-[60px] left-0 bottom-0 z-40 bg-canvas border-r border-hairline overflow-y-auto overflow-x-hidden transition-all duration-200 ease-in-out scrollbar-thin">
  
  <!-- 1. EXPANDED SIDEBAR VIEW (240px wide) -->
  <div id="sidebar-expanded" class="sidebar-expanded-content flex flex-col h-full py-3 px-3 space-y-4 w-60">
    
    <!-- Core Navigation Group -->
    <div class="space-y-1">
      <a 
        href="/" 
        class={`flex items-center gap-4 px-3 py-2.5 rounded-md text-xs font-mono font-medium transition-colors ${activePage === 'home' ? 'bg-canvas-soft text-primary font-bold border border-hairline/80' : 'text-ink hover:bg-canvas-soft'}`}
      >
        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <span class="truncate">Home</span>
      </a>

      <a 
        href="/courses" 
        class={`flex items-center gap-4 px-3 py-2.5 rounded-md text-xs font-mono font-medium transition-colors ${activePage === 'courses' ? 'bg-canvas-soft text-primary font-bold border border-hairline/80' : 'text-ink hover:bg-canvas-soft'}`}
      >
        <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        <span class="truncate">Courses</span>
      </a>
    </div>

    <div class="border-b border-hairline/60"></div>

    <!-- YouTube Style Subscriptions Section Header & Dynamic Subscribed Channels List -->
    <div class="space-y-1">
      <a 
        href="/subscriptions" 
        class={`px-3 py-1.5 text-xs font-mono font-bold uppercase tracking-wider flex items-center justify-between group rounded-md transition-colors ${activePage === 'subscriptions' ? 'text-primary' : 'text-ink-strong'}`}
      >
        <div class="flex items-center gap-2">
          <span>Subscriptions</span>
          <span id="sidebar-sub-badge" class="text-[9.5px] font-mono font-bold bg-primary text-on-primary px-1.5 py-0.5 rounded-full hidden">0</span>
        </div>
        <svg class="h-3.5 w-3.5 text-mute group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>

      <!-- Subscribed Creator Channels Container (Populated dynamically on client with ONLY subscribed creators) -->
      <div id="sidebar-channels-list" class="space-y-0.5 scrollbar-none" data-creators={JSON.stringify(creatorsList)}>
        <p id="sidebar-empty-subs" class="px-3 py-2 text-xs font-mono text-mute hidden">No subscriptions yet</p>
      </div>

      <!-- Show More Toggle Button -->
      <button 
        id="sidebar-show-more-btn" 
        type="button" 
        class="w-full flex items-center gap-3 px-3 py-2 text-xs font-mono text-mute hover:text-ink rounded-md hover:bg-canvas-soft transition-colors text-left cursor-pointer mt-1 hidden"
      >
        <svg id="sidebar-show-more-icon" class="h-4 w-4 shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
        <span id="sidebar-show-more-text">Show more</span>
      </button>
    </div>

    <div class="border-b border-hairline/60"></div>

    <!-- YouTube Style "You" Section Header & Items -->
    <div class="space-y-1">
      <a 
        href="/subscriptions" 
        class="px-3 py-1.5 text-xs font-mono font-bold text-ink-strong uppercase tracking-wider flex items-center justify-between group"
      >
        <span>You</span>
        <svg class="h-3.5 w-3.5 text-mute group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>

      <a href="/subscriptions" class="flex items-center gap-4 px-3 py-2.5 rounded-md text-xs font-mono text-body hover:text-ink hover:bg-canvas-soft transition-colors">
        <svg class="h-5 w-5 shrink-0 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        <span class="truncate">Profile</span>
      </a>

      <a href="/watch-later" class="flex items-center gap-4 px-3 py-2.5 rounded-md text-xs font-mono text-body hover:text-ink hover:bg-canvas-soft transition-colors group">
        <svg class="h-5 w-5 shrink-0 text-mute group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="truncate flex-grow">Watch later</span>
        <span id="sidebar-watch-later-badge" class="text-[9.5px] font-mono font-bold bg-primary text-on-primary px-1.5 py-0.5 rounded-full hidden">0</span>
      </a>
    </div>

    <div class="border-b border-hairline/60"></div>

    <!-- Sidebar Footer -->
    <div class="px-3 py-2 text-[10px] font-mono text-mute/60 leading-relaxed space-y-1">
      <div>FreeYTCourses Hub</div>
      <div>© 2026 YouTube Style Learning</div>
    </div>
  </div>

  <!-- 2. COLLAPSED MINI SIDEBAR VIEW (72px wide) -->
  <div id="sidebar-collapsed" class="sidebar-collapsed-content flex flex-col items-center py-3 space-y-4 w-[72px]">
    
    <a 
      href="/" 
      class={`flex flex-col items-center justify-center w-14 py-2.5 rounded-lg transition-colors group ${activePage === 'home' ? 'text-primary bg-canvas-soft' : 'text-ink hover:bg-canvas-soft'}`}
      title="Home"
    >
      <svg class="h-5 w-5 shrink-0 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      <span class="text-[10px] font-mono tracking-tight mt-1 text-center leading-none">Home</span>
    </a>

    <a 
      href="/courses" 
      class={`flex flex-col items-center justify-center w-14 py-2.5 rounded-lg transition-colors group ${activePage === 'courses' ? 'text-primary bg-canvas-soft' : 'text-ink hover:bg-canvas-soft'}`}
      title="Courses"
    >
      <svg class="h-5 w-5 shrink-0 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
      <span class="text-[10px] font-mono tracking-tight mt-1 text-center leading-none">Courses</span>
    </a>

    <a 
      href="/subscriptions" 
      class={`flex flex-col items-center justify-center w-14 py-2.5 rounded-lg transition-colors group relative ${activePage === 'subscriptions' ? 'text-primary bg-canvas-soft' : 'text-ink hover:bg-canvas-soft'}`}
      title="Subscriptions"
    >
      <svg class="h-5 w-5 shrink-0 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      <span class="text-[10px] font-mono tracking-tight mt-1 text-center leading-none">Subscriptions</span>
      <span id="mini-sidebar-sub-badge" class="absolute top-1 right-2 bg-primary text-on-primary text-[8px] font-mono font-bold px-1 rounded-full hidden">0</span>
    </a>

    <a 
      href="/watch-later" 
      class="flex flex-col items-center justify-center w-14 py-2.5 rounded-lg text-ink hover:bg-canvas-soft transition-colors group relative"
      title="Watch later"
    >
      <svg class="h-5 w-5 shrink-0 text-mute group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span class="text-[10px] font-mono tracking-tight mt-1 text-center leading-none">You</span>
    </a>

  </div>
</aside>

<script>
  // Global Sidebar Interactivity & LocalStorage Persistence
  function initSidebar() {
    const toggleBtn = document.getElementById('sidebar-toggle-btn');
    const backdrop = document.getElementById('sidebar-backdrop');
    const showMoreBtn = document.getElementById('sidebar-show-more-btn');
    const showMoreText = document.getElementById('sidebar-show-more-text');
    const showMoreIcon = document.getElementById('sidebar-show-more-icon');
    const subBadges = [
      document.getElementById('sidebar-sub-badge'),
      document.getElementById('mini-sidebar-sub-badge'),
      document.getElementById('nav-sub-badge')
    ];

    const STORAGE_KEY = 'freeyt_sidebar_state';

    function setSidebarState(state: string) {
      document.documentElement.setAttribute('data-sidebar-state', state);
      localStorage.setItem(STORAGE_KEY, state);
    }

    toggleBtn?.addEventListener('click', () => {
      const isMobile = window.innerWidth < 768;
      if (isMobile) {
        const currentMobile = document.documentElement.getAttribute('data-sidebar-mobile');
        const nextMobile = currentMobile === 'open' ? 'closed' : 'open';
        document.documentElement.setAttribute('data-sidebar-mobile', nextMobile);
      } else {
        const currentState = document.documentElement.getAttribute('data-sidebar-state') || 'expanded';
        const nextState = currentState === 'expanded' ? 'collapsed' : 'expanded';
        setSidebarState(nextState);
      }
    });

    backdrop?.addEventListener('click', () => {
      document.documentElement.setAttribute('data-sidebar-mobile', 'closed');
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.documentElement.setAttribute('data-sidebar-mobile', 'closed');
      }
    });

    const INITIAL_LIMIT = 6;
    let isShowingAll = false;
    showMoreBtn?.addEventListener('click', () => {
      isShowingAll = !isShowingAll;
      const channelsContainer = document.getElementById('sidebar-channels-list');
      const items = document.querySelectorAll('.sidebar-channel-item');
      items.forEach((el, idx) => {
        if (idx >= INITIAL_LIMIT) {
          if (isShowingAll) {
            el.classList.remove('hidden');
          } else {
            el.classList.add('hidden');
          }
        }
      });

      if (channelsContainer) {
        if (isShowingAll) {
          channelsContainer.classList.add('max-h-64', 'overflow-y-auto', 'scrollbar-none');
        } else {
          channelsContainer.classList.remove('max-h-64', 'overflow-y-auto', 'scrollbar-none');
          channelsContainer.scrollTop = 0;
        }
      }

      if (showMoreText) showMoreText.textContent = isShowingAll ? 'Show less' : 'Show more';
      if (showMoreIcon) {
        showMoreIcon.style.transform = isShowingAll ? 'rotate(180deg)' : 'rotate(0deg)';
      }
    });

    function updateSubscriptionsState() {
      try {
        let raw = localStorage.getItem('freeyt_subscribed_creators');
        let subs = raw ? JSON.parse(raw) : [];
        if (!Array.isArray(subs) || subs.length === 0) {
          const defaultSubs = [
            'dr-angela-thorne', 
            'marcus-sterling', 
            'elena-rostova', 
            'julian-kade', 
            'sarah-lindqvist', 
            'prof-alan-vance'
          ];
          localStorage.setItem('freeyt_subscribed_creators', JSON.stringify(defaultSubs));
          subs = defaultSubs;
        }
        
        subBadges.forEach(badge => {
          if (badge) {
            if (Array.isArray(subs) && subs.length > 0) {
              badge.textContent = String(subs.length);
              badge.classList.remove('hidden');
            } else {
              badge.classList.add('hidden');
            }
          }
        });

        const channelsContainer = document.getElementById('sidebar-channels-list');
        const emptyMsg = document.getElementById('sidebar-empty-subs');
        if (!channelsContainer) return;

        const rawCreators = channelsContainer.getAttribute('data-creators') || '[]';
        let creators: any[] = [];
        try {
          creators = JSON.parse(rawCreators);
        } catch (err) {
          creators = [];
        }

        // Filter creators list to ONLY include those in the user's subscribed array
        const subscribedCreators = creators.filter((c: any) => Array.isArray(subs) && subs.includes(c.slug));

        // Update expanded sidebar channels
        const existingItems = channelsContainer.querySelectorAll('.sidebar-channel-item');
        existingItems.forEach(item => item.remove());

        if (subscribedCreators.length === 0) {
          if (emptyMsg) emptyMsg.classList.remove('hidden');
          if (showMoreBtn) showMoreBtn.classList.add('hidden');
        } else {
          if (emptyMsg) emptyMsg.classList.add('hidden');

          subscribedCreators.forEach((creator: any, idx: number) => {
            const a = document.createElement('a');
            a.href = `/creators/${creator.slug}`;
            a.className = `sidebar-channel-item flex items-center gap-3 px-3 py-2 rounded-md hover:bg-canvas-soft transition-colors group cursor-pointer ${idx >= INITIAL_LIMIT && !isShowingAll ? 'hidden' : ''}`;
            a.setAttribute('data-creator-slug', creator.slug);
            a.innerHTML = `
              <img 
                src="${creator.logo}" 
                alt="${creator.name}" 
                class="h-6 w-6 rounded-full object-cover border border-hairline group-hover:border-primary shrink-0 transition-colors" 
              />
              <span class="text-xs text-body group-hover:text-ink truncate flex-grow font-normal leading-none">${creator.name}</span>
              <span class="h-1.5 w-1.5 rounded-full bg-primary shrink-0 opacity-90 group-hover:opacity-100" title="Active creator channel"></span>
            `;
            channelsContainer.appendChild(a);
          });

          if (subscribedCreators.length > INITIAL_LIMIT) {
            if (showMoreBtn) showMoreBtn.classList.remove('hidden');
          } else {
            if (showMoreBtn) showMoreBtn.classList.add('hidden');
          }
        }
      } catch (e) {
        console.error("Error updating sidebar subscriptions:", e);
      }
    }

    function updateWatchLaterState() {
      try {
        const raw = localStorage.getItem('freeyt_watch_later');
        const wl = raw ? JSON.parse(raw) : [];
        const badge = document.getElementById('sidebar-watch-later-badge');
        if (badge) {
          if (Array.isArray(wl) && wl.length > 0) {
            badge.textContent = String(wl.length);
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
          }
        }
      } catch (e) {
        console.error(e);
      }
    }

    updateSubscriptionsState();
    updateWatchLaterState();

    window.addEventListener('subscriptionsChanged', updateSubscriptionsState);
    window.addEventListener('watchLaterChanged', updateWatchLaterState);
    window.addEventListener('storage', () => {
      updateSubscriptionsState();
      updateWatchLaterState();
    });
  }

  // Run init on DOMContentLoaded or view transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebar);
  } else {
    initSidebar();
  }
</script>
