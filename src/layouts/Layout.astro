---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "FreeYTCourses - A Curated Hub of premium, text-rich and highly optimized free YouTube courses." } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | FreeYTCourses</title>
		<meta name="description" content={description} />
		<!-- Google Fonts Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-canvas text-ink font-sans selection:bg-primary/30 selection:text-primary">
		<slot />
	</body>
</html>
