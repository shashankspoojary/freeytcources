---
import Layout from '../../layouts/Layout.astro';

const title = "Secure Course Upload Console";
const description = "Manually ingest new courses and syllabus layouts into the curriculum directory.";
---

<Layout title={title} description={description} activePage="admin" hideSidebar={true}>


  <main class="max-w-4xl mx-auto px-6 py-12 md:py-20 flex flex-col items-center justify-center min-h-[calc(100vh-140px)]">
    
    <!-- Lock Screen / Passcode Entry -->
    <div id="lock-screen" class="w-full max-w-md bg-canvas border border-hairline rounded-md p-8 text-center transition-all duration-300 transform scale-100 opacity-100">
      <div class="h-16 w-16 mx-auto mb-6 rounded-full bg-canvas-soft border border-hairline flex items-center justify-center text-primary">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
      </div>
      
      <div class="inline-block font-mono text-[10px] text-primary uppercase tracking-[2.52px] mb-3 bg-primary/10 px-2.5 py-1 rounded-pill border border-primary/20">
        Access Restricted
      </div>
      
      <h1 class="text-2xl font-light text-ink-strong tracking-tight mb-3">Admin Lockscreen</h1>
      <p class="text-sm text-body mb-8 font-light leading-relaxed">
        Authentication required. Enter the administrative passcode to access the course ingestion console.
      </p>

      <form id="passcode-form" class="space-y-4 text-left">
        <div>
          <label for="passcode" class="block text-xs font-mono uppercase tracking-wider text-mute mb-2">Security Access Code</label>
          <input 
            type="password" 
            id="passcode" 
            placeholder="Hint: admin123" 
            class="w-full bg-canvas-soft border border-hairline text-ink rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder-mute/40"
            required
          />
          <p id="passcode-error" class="hidden text-xs text-red-500 mt-2 font-mono">❌ Invalid passcode. Access denied.</p>
        </div>

        <button 
          type="submit" 
          class="w-full bg-primary text-on-primary font-mono uppercase text-sm font-bold tracking-wider py-3.5 px-4 rounded-sm hover:bg-primary-soft transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-canvas cursor-pointer"
        >
          Unlock Console
        </button>
      </form>
    </div>

    <!-- Admin Upload Console (Hidden Initially) -->
    <div id="admin-console" class="hidden w-full max-w-3xl space-y-8 opacity-0 transform translate-y-4 transition-all duration-500">
      
      <!-- Console Header -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 border-b border-hairline pb-6">
        <div>
          <div class="inline-block font-mono text-[10px] text-primary uppercase tracking-[2.52px] mb-2 bg-primary/10 px-2.5 py-1 rounded-pill border border-primary/20">
            Secure Admin Session Active
          </div>
          <h1 class="text-3xl font-light text-ink-strong tracking-[-0.65px]">Course Ingestion Console</h1>
          <p class="text-sm text-body font-light mt-1">
            Build, review, and export AdSense-compliant course syllabus structures.
          </p>
        </div>
        <div class="flex items-center gap-3">
          <a 
            href="/admin/courses" 
            class="text-xs font-mono uppercase bg-canvas-soft border border-hairline hover:border-primary text-ink hover:text-primary px-3.5 py-2 rounded-sm transition-all flex items-center gap-2 cursor-pointer font-medium"
          >
            <svg class="h-3.5 w-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            Submitted Courses &rarr;
          </a>

          <button 
            id="lock-console-btn" 
            class="text-xs font-mono uppercase border border-hairline hover:border-red-500/50 hover:text-red-400 text-body px-3 py-2 rounded-sm transition-all flex items-center gap-2 cursor-pointer"
          >
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 00-2 2z" />
            </svg>
            Lock Console
          </button>
        </div>
      </div>

      <!-- Main Form -->
      <form id="upload-form" class="space-y-8">
        
        <!-- Section 1: Course Metadata -->
        <div class="bg-canvas-soft border border-hairline rounded-md p-6 space-y-6">
          <div class="flex items-center gap-2 mb-2 border-b border-hairline/40 pb-3">
            <span class="text-xs font-mono text-primary font-bold">01/</span>
            <h2 class="text-sm font-mono uppercase tracking-wider text-ink-strong font-semibold">Course Meta-Data</h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="course-title" class="block text-xs font-mono uppercase tracking-wider text-mute mb-2">Course Title</label>
              <input 
                type="text" 
                id="course-title" 
                placeholder="e.g. Advanced AI Agents Masterclass"
                class="w-full bg-canvas border border-hairline text-ink rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder-mute/40"
                required
              />
            </div>

            <div>
              <label for="youtube-link" class="block text-xs font-mono uppercase tracking-wider text-mute mb-2">YouTube Playlist Link / ID</label>
              <input 
                type="text" 
                id="youtube-link" 
                placeholder="e.g. https://www.youtube.com/playlist?list=..."
                class="w-full bg-canvas border border-hairline text-ink rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder-mute/40"
                required
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="category" class="block text-xs font-mono uppercase tracking-wider text-mute mb-2">Category</label>
              <div class="relative">
                <select 
                  id="category" 
                  class="w-full appearance-none bg-canvas border border-hairline text-ink rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all cursor-pointer pr-10"
                  required
                >
                  <option value="" disabled selected>Select Category</option>
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-mute">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </div>

              <!-- Interactive Category Manager (Add by typing & Remove) -->
              <div class="mt-3 bg-canvas-soft/80 border border-hairline rounded-sm p-3 space-y-2.5">
                <div class="flex items-center justify-between">
                  <span class="text-[11px] font-mono uppercase tracking-wider text-mute font-semibold">Category Manager</span>
                  <span id="cat-count-badge" class="text-[10px] font-mono text-primary font-bold">0 Categories</span>
                </div>

                <!-- Add Category Row -->
                <div class="flex items-center gap-2">
                  <input 
                    type="text" 
                    id="new-category-input" 
                    placeholder="Type new category name..." 
                    class="flex-1 bg-canvas border border-hairline text-ink rounded-sm px-3 py-1.5 text-xs focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20 transition-all font-mono placeholder:text-mute/40"
                  />
                  <button 
                    type="button" 
                    id="add-category-btn" 
                    class="bg-primary text-on-primary font-mono text-xs uppercase font-bold px-3 py-1.5 rounded-sm hover:bg-primary-soft transition-colors cursor-pointer shrink-0 flex items-center gap-1"
                  >
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                    </svg>
                    Add
                  </button>
                </div>
                <p id="category-error-msg" class="text-[10px] font-mono text-red-400 hidden"></p>

                <!-- Removable Category Chips -->
                <div id="category-chips-container" class="flex flex-wrap gap-1.5 pt-1">
                  <!-- Dynamically populated chips -->
                </div>
              </div>
            </div>

            <div>
              <label for="author" class="block text-xs font-mono uppercase tracking-wider text-mute mb-2">Author Name</label>
              <input 
                type="text" 
                id="author" 
                placeholder="e.g. Dr. Angela Thorne"
                class="w-full bg-canvas border border-hairline text-ink rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder-mute/40"
                required
              />
              <div class="flex items-center gap-2.5 mt-2">
                <img id="author-avatar-preview" class="h-6 w-6 rounded-full object-cover border border-hairline hidden" />
                <span id="author-avatar-status" class="text-[10px] font-mono text-mute"></span>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-hairline/40">
            <div>
              <label for="course-language" class="block text-xs font-mono uppercase tracking-wider text-mute mb-2">Language</label>
              <div class="flex gap-2">
                <div class="relative flex-grow">
                  <select 
                    id="course-language" 
                    class="w-full appearance-none bg-canvas border border-hairline text-ink rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all cursor-pointer pr-10"
                    required
                  >
                    <option value="" disabled selected>Select Language</option>
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-mute">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </div>
                <button
                  type="button"
                  id="add-custom-lang-btn"
                  class="px-4 py-3 bg-canvas border border-hairline hover:border-primary text-xs font-mono uppercase text-body hover:text-primary rounded-sm transition-all shrink-0 cursor-pointer"
                >
                  New Language
                </button>
              </div>
            </div>

            <div id="custom-lang-container" class="hidden">
              <label for="custom-language" class="block text-xs font-mono uppercase tracking-wider text-mute mb-2">Add Custom Language</label>
              <div class="flex gap-2">
                <input 
                  type="text" 
                  id="custom-language" 
                  placeholder="e.g. Spanish"
                  class="w-full bg-canvas border border-hairline text-ink rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder-mute/40"
                />
                <button
                  type="button"
                  id="save-custom-lang-btn"
                  class="px-4 py-3 bg-primary text-on-primary text-xs font-mono uppercase font-bold rounded-sm hover:bg-primary-soft transition-all shrink-0 cursor-pointer"
                >
                  Add Option
                </button>
              </div>
            </div>
          </div>

          <!-- Course Tags / Tools Input Section -->
          <div class="pt-4 border-t border-hairline/40">
            <label for="tag-input" class="block text-xs font-mono uppercase tracking-wider text-mute mb-2">Course Tags / Tools (Optional)</label>
            <div class="flex gap-2 mb-3">
              <input 
                type="text" 
                id="tag-input" 
                placeholder="e.g. Python, LangChain, Next.js (Press Enter or click Add)"
                class="flex-grow bg-canvas border border-hairline text-ink rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder-mute/40"
              />
              <button
                type="button"
                id="add-tag-btn"
                class="px-4 py-3 bg-canvas border border-hairline hover:border-primary text-xs font-mono uppercase text-body hover:text-primary rounded-sm transition-all shrink-0 cursor-pointer"
              >
                Add Tag
              </button>
            </div>
            
            <!-- Removable Tags Chip Badges Container -->
            <div id="tags-chips-container" class="flex flex-wrap gap-2 min-h-[36px] p-2.5 bg-canvas/40 border border-hairline/60 rounded-sm">
              <span class="text-xs font-mono text-mute/50 self-center" id="no-tags-msg">No tags added yet. Type a tag above and click Add.</span>
            </div>
          </div>
        </div>

        <!-- Section 2: Extended Summary (AdSense word-count check) -->
        <div class="bg-canvas-soft border border-hairline rounded-md p-6 space-y-6">
          <div class="flex justify-between items-center border-b border-hairline/40 pb-3">
            <div class="flex items-center gap-2">
              <span class="text-xs font-mono text-primary font-bold">02/</span>
              <h2 class="text-sm font-mono uppercase tracking-wider text-ink-strong font-semibold">Extended Overview & Critique</h2>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[10px] font-mono uppercase tracking-wider text-mute">AdSense Criteria:</span>
              <span id="adsense-badge" class="px-2.5 py-0.5 rounded-full text-[10px] font-mono border border-red-500/20 bg-red-500/10 text-red-400 flex items-center gap-1">
                <span class="h-1.5 w-1.5 rounded-full bg-red-500 animate-pulse"></span>
                Incomplete (<span id="words-needed">200</span> left)
              </span>
            </div>
          </div>

          <div>
            <div class="flex justify-between items-center mb-2">
              <label for="overview" class="block text-xs font-mono uppercase tracking-wider text-mute">Extended Summary (Markdown Supported)</label>
              <span class="text-xs font-mono text-mute">
                Words: <span id="word-count" class="text-ink font-semibold">0</span> / 200 | Chars: <span id="char-count" class="text-ink">0</span>
              </span>
            </div>
            
            <textarea 
              id="overview" 
              rows="8"
              placeholder="Provide a comprehensive review of the course. Must be at least 200 words long to satisfy SEO/AdSense optimization layers. Detail the teaching style, strengths, flaws, and required tools."
              class="w-full bg-canvas border border-hairline text-ink rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder-mute/40 font-light leading-relaxed mb-1"
              required
            ></textarea>
            
            <div id="adsense-warning" class="mt-3 p-3 bg-red-500/5 border border-red-500/20 rounded-sm flex items-start gap-2.5 transition-all duration-300">
              <svg class="h-4 w-4 text-red-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
              <p class="text-xs text-body font-light">
                <strong class="text-ink-strong">AdSense Requirement Warning:</strong> Your overview review text is currently under 200 words. Search crawlers expect editorial substance for high-quality monetization directories.
              </p>
            </div>
          </div>
        </div>

        <!-- Section 3: Dynamic Syllabus Modules -->
        <div class="bg-canvas-soft border border-hairline rounded-md p-6 space-y-6">
          <div class="flex justify-between items-center border-b border-hairline/40 pb-3">
            <div class="flex items-center gap-2">
              <span class="text-xs font-mono text-primary font-bold">03/</span>
              <h2 class="text-sm font-mono uppercase tracking-wider text-ink-strong font-semibold">Syllabus & Chapter Modules</h2>
            </div>
            <span class="text-xs font-mono text-mute">
              Active Modules: <span id="module-count" class="text-primary font-bold">0</span>
            </span>
          </div>

          <!-- Modules Container -->
          <div id="modules-list" class="space-y-4">
            <!-- Dynamic rows will be inserted here by JavaScript -->
          </div>

          <!-- Add Module Control -->
          <button 
            type="button" 
            id="add-module-btn"
            class="w-full flex items-center justify-center gap-2 py-3 border border-dashed border-hairline hover:border-primary/50 text-xs font-mono uppercase text-body hover:text-primary rounded-sm transition-all cursor-pointer bg-canvas/30"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add Course Module
          </button>
        </div>

        <!-- Form Submission Controls -->
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-4 border-t border-hairline">
          <button 
            type="button" 
            id="reset-form-btn"
            class="w-full sm:w-auto px-6 py-3.5 border border-hairline hover:border-red-500/30 text-xs font-mono uppercase text-body hover:text-red-400 rounded-sm transition-all cursor-pointer bg-transparent"
          >
            Reset Form
          </button>
          
          <button 
            type="submit" 
            class="w-full sm:w-auto bg-primary text-on-primary font-mono uppercase text-sm font-bold tracking-wider py-3.5 px-8 rounded-sm hover:bg-primary-soft transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-canvas cursor-pointer flex items-center justify-center gap-2"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
            </svg>
            Submit Course payload
          </button>
        </div>
      </form>

        <!-- Section 4: Submitted Courses Navigation Card -->
        <div class="bg-canvas-soft border border-hairline rounded-md p-6 flex flex-col sm:flex-row items-center justify-between gap-4 mt-8">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-mono text-primary font-bold">04/</span>
              <h2 class="text-sm font-mono uppercase tracking-wider text-ink-strong font-semibold">Submitted Courses Directory</h2>
            </div>
            <p class="text-xs text-body font-light">
              All active cataloged courses are managed on a dedicated directory page to handle large volumes of submissions.
            </p>
          </div>
          <a 
            href="/admin/courses" 
            class="px-5 py-3 bg-primary text-on-primary font-mono text-xs uppercase font-bold tracking-wider rounded-sm hover:bg-primary-soft transition-all flex items-center gap-2 shrink-0 shadow-md cursor-pointer"
          >
            <span>Manage Submitted Courses &rarr;</span>
          </a>
        </div>
      </div>

    </main>

  <!-- Success Toast Alert Component -->
  <div 
    id="success-toast" 
    class="fixed bottom-6 right-6 z-50 bg-canvas border border-hairline rounded-md p-4 shadow-2xl max-w-sm flex gap-3 transform translate-y-12 opacity-0 pointer-events-none transition-all duration-300 border-l-4 border-l-primary"
  >
    <div class="h-8 w-8 rounded-full bg-primary/10 border border-primary/20 text-primary flex items-center justify-center shrink-0">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <div>
      <h3 class="text-sm font-mono uppercase tracking-wider text-ink-strong font-semibold">Submission Mock Success</h3>
      <p class="text-xs text-body font-light mt-0.5 leading-relaxed">
        Course structure has been validated and compiled. The complete JSON payload was printed to the developer console.
      </p>
    </div>
    <button 
      id="close-toast-btn"
      class="text-mute hover:text-ink transition-colors ml-2 self-start cursor-pointer focus:outline-none bg-transparent border-none"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Custom Delete Confirmation Modal Component -->
  <div 
    id="delete-confirm-modal" 
    class="fixed inset-0 z-50 flex items-center justify-center bg-canvas/60 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300 hidden"
  >
    <div id="delete-modal-card" class="bg-canvas border border-hairline rounded-md p-6 max-w-sm w-full mx-4 shadow-2xl space-y-6 transform scale-95 transition-all duration-300">
      <div class="flex items-center gap-3 text-red-500">
        <div class="h-10 w-10 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center shrink-0">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <h3 class="text-sm font-mono uppercase tracking-wider font-semibold">Confirm Deletion</h3>
      </div>
      
      <p class="text-xs text-body font-light leading-relaxed">
        Are you sure you want to permanently delete <span id="delete-course-title-display" class="font-semibold text-ink-strong">this course</span>? This action cannot be undone.
      </p>
      
      <div class="flex justify-end gap-3 pt-4 border-t border-hairline/40">
        <button 
          id="cancel-delete-btn"
          type="button"
          class="px-4 py-2 border border-hairline hover:border-ink/20 text-xs font-mono uppercase text-mute hover:text-ink rounded-sm transition-all cursor-pointer bg-transparent"
        >
          Cancel
        </button>
        <button 
          id="confirm-delete-btn"
          type="button"
          class="px-4 py-2 bg-red-600 text-white font-mono uppercase text-xs font-bold tracking-wider rounded-sm hover:bg-red-500 transition-colors duration-200 cursor-pointer"
        >
          Yes, Delete
        </button>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { db } from '../../lib/firebase.js';
  import { doc, setDoc } from 'firebase/firestore';

  // DOM Elements
  const lockScreen = document.getElementById('lock-screen');
  const passcodeForm = document.getElementById('passcode-form');
  const passcodeField = document.getElementById('passcode') as HTMLInputElement;
  const passcodeError = document.getElementById('passcode-error');
  
  const adminConsole = document.getElementById('admin-console');
  const lockConsoleBtn = document.getElementById('lock-console-btn');
  const uploadForm = document.getElementById('upload-form') as HTMLFormElement;
  const resetFormBtn = document.getElementById('reset-form-btn');
  
  // Overview counter inputs
  const overviewInput = document.getElementById('overview') as HTMLTextAreaElement;
  const wordCountDisplay = document.getElementById('word-count');
  const charCountDisplay = document.getElementById('char-count');
  const adsenseBadge = document.getElementById('adsense-badge');
  const adsenseWarning = document.getElementById('adsense-warning');
  
