  // Manual Tags Elements
  const tagInput = document.getElementById('tag-input') as HTMLInputElement;
  const addTagBtn = document.getElementById('add-tag-btn');
  const tagsChipsContainer = document.getElementById('tags-chips-container');
  let currentTags: string[] = [];

  function renderTagChips() {
    if (!tagsChipsContainer) return;
    tagsChipsContainer.innerHTML = '';
    
    if (currentTags.length === 0) {
      tagsChipsContainer.innerHTML = `<span class="text-xs font-mono text-mute/50 self-center" id="no-tags-msg">No tags added yet. Type a tag above and click Add.</span>`;
      return;
    }

    currentTags.forEach((tag, idx) => {
      const chip = document.createElement('div');
      chip.className = 'inline-flex items-center gap-1.5 px-3 py-1 bg-canvas border border-primary/40 text-primary rounded-sm text-xs font-mono shadow-sm';
      chip.innerHTML = `
        <span>${tag}</span>
        <button type="button" class="remove-tag-btn hover:text-red-400 focus:outline-none cursor-pointer text-sm font-bold ml-1" data-idx="${idx}" title="Remove tag">&times;</button>
      `;
      
      chip.querySelector('.remove-tag-btn')?.addEventListener('click', () => {
        currentTags.splice(idx, 1);
        renderTagChips();
      });

      tagsChipsContainer.appendChild(chip);
    });
  }

  function addTagFromInput() {
    if (!tagInput) return;
    const val = tagInput.value.trim();
    if (val) {
      const splitTags = val.split(/[,;]+/).map(t => t.trim()).filter(Boolean);
      splitTags.forEach(t => {
        if (!currentTags.includes(t)) {
          currentTags.push(t);
        }
      });
      tagInput.value = '';
      renderTagChips();
    }
  }

  addTagBtn?.addEventListener('click', addTagFromInput);
  tagInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      addTagFromInput();
    }
  });

  // Category Storage & Manager Integration
  const DEFAULT_CATEGORIES = ["AI Engineering", "Video Editing", "Coding Skills"];
  const CAT_STORAGE_KEY = 'freeyt_categories';

  function getStoredCategories(): string[] {
    try {
      const raw = localStorage.getItem(CAT_STORAGE_KEY);
      const parsed = raw ? JSON.parse(raw) : null;
      if (Array.isArray(parsed) && parsed.length > 0) return parsed;
    } catch (e) {}
    localStorage.setItem(CAT_STORAGE_KEY, JSON.stringify(DEFAULT_CATEGORIES));
    return DEFAULT_CATEGORIES;
  }

  function saveStoredCategories(cats: string[]) {
    localStorage.setItem(CAT_STORAGE_KEY, JSON.stringify(cats));
    window.dispatchEvent(new CustomEvent('categoriesChanged', { detail: cats }));
  }

  const categorySelect = document.getElementById('category') as HTMLSelectElement;
  const newCatInput = document.getElementById('new-category-input') as HTMLInputElement;
  const addCatBtn = document.getElementById('add-category-btn');
  const catChipsContainer = document.getElementById('category-chips-container');
  const catCountBadge = document.getElementById('cat-count-badge');
  const catErrorMsg = document.getElementById('category-error-msg');

  function renderCategoryManager() {
    const cats = getStoredCategories();
    
    if (catCountBadge) {
      catCountBadge.textContent = `${cats.length} Categories`;
    }

    // Update Select Dropdown
    if (categorySelect) {
      const currentSelected = categorySelect.value;
      categorySelect.innerHTML = '<option value="" disabled>Select Category</option>';
      cats.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c;
        opt.textContent = c;
        if (c === currentSelected) {
          opt.selected = true;
        }
        categorySelect.appendChild(opt);
      });
      if (!currentSelected) {
        categorySelect.value = "";
      }
    }

    // Update Removable Chips
    if (catChipsContainer) {
      catChipsContainer.innerHTML = '';
      cats.forEach(cat => {
        const chip = document.createElement('div');
        chip.className = 'inline-flex items-center gap-1 px-2.5 py-1 bg-canvas border border-hairline hover:border-primary/40 text-ink rounded-sm text-xs font-mono transition-colors group';
        chip.innerHTML = `
          <span>${cat}</span>
          <button type="button" class="remove-category-chip-btn text-mute hover:text-red-400 focus:outline-none cursor-pointer text-xs font-bold ml-1 transition-colors" data-category="${cat}" title="Remove category">&times;</button>
        `;

        chip.querySelector('.remove-category-chip-btn')?.addEventListener('click', (e) => {
          e.stopPropagation();
          removeCategory(cat);
        });

        catChipsContainer.appendChild(chip);
      });
    }
  }

  function addCategoryFromInput() {
    if (!newCatInput) return;
    const rawVal = newCatInput.value.trim();
    if (!rawVal) {
      showCatError("Please enter a category name.");
      return;
    }

    const currentCats = getStoredCategories();
    const exists = currentCats.some(c => c.toLowerCase() === rawVal.toLowerCase());
    if (exists) {
      showCatError(`Category '${rawVal}' already exists.`);
      return;
    }

    hideCatError();
    const updated = [...currentCats, rawVal];
    saveStoredCategories(updated);
    renderCategoryManager();

    // Auto-select the newly added category in the dropdown
    if (categorySelect) {
      categorySelect.value = rawVal;
    }

    newCatInput.value = '';
    
    // Show success toast feedback
    if (typeof successToast !== 'undefined' && successToast) {
      const toastTitle = successToast.querySelector('h3');
      const toastDesc = successToast.querySelector('p');
      if (toastTitle) toastTitle.textContent = "Category Added";
      if (toastDesc) toastDesc.textContent = `New category '${rawVal}' has been added successfully.`;
      triggerToast();
    }
  }

  function removeCategory(catToRemove: string) {
    const currentCats = getStoredCategories();
    if (currentCats.length <= 1) {
      showCatError("At least one category must remain.");
      return;
    }

    hideCatError();
    const updated = currentCats.filter(c => c !== catToRemove);
    saveStoredCategories(updated);
    renderCategoryManager();

    // Show toast feedback
    if (typeof successToast !== 'undefined' && successToast) {
      const toastTitle = successToast.querySelector('h3');
      const toastDesc = successToast.querySelector('p');
      if (toastTitle) toastTitle.textContent = "Category Removed";
      if (toastDesc) toastDesc.textContent = `Category '${catToRemove}' has been removed.`;
      triggerToast();
    }
  }

  function showCatError(msg: string) {
    if (catErrorMsg) {
      catErrorMsg.textContent = msg;
      catErrorMsg.classList.remove('hidden');
    }
  }

  function hideCatError() {
    if (catErrorMsg) {
      catErrorMsg.classList.add('hidden');
    }
  }

  addCatBtn?.addEventListener('click', addCategoryFromInput);
  newCatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      addCategoryFromInput();
    }
  });

  window.addEventListener('categoriesChanged', renderCategoryManager);
  window.addEventListener('storage', (e) => {
    if (e.key === CAT_STORAGE_KEY) renderCategoryManager();
  });

