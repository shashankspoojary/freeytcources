  const closeToastBtn = document.getElementById('close-toast-btn');

  // Language Elements
  const languageSelect = document.getElementById('course-language') as HTMLSelectElement;
  const customLangContainer = document.getElementById('custom-lang-container');
  const addCustomLangBtn = document.getElementById('add-custom-lang-btn');
  const customLangInput = document.getElementById('custom-language') as HTMLInputElement;
  const saveCustomLangBtn = document.getElementById('save-custom-lang-btn');
