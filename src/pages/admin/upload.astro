  function updateModuleCount() {
    if (modulesList && moduleCountDisplay) {
      const count = modulesList.children.length;
      moduleCountDisplay.textContent = String(count);
    }
  }

  addModuleBtn?.addEventListener('click', () => createModuleRow());

  // Toast controls
  let toastTimeout: number;
  
  function triggerToast() {
    if (successToast) {
      successToast.classList.remove('translate-y-12', 'opacity-0', 'pointer-events-none');
      successToast.classList.add('translate-y-0', 'opacity-100');
      
      clearTimeout(toastTimeout);
      toastTimeout = window.setTimeout(dismissToast, 4000);
    }
  }

  function dismissToast() {
    if (successToast) {
      successToast.classList.remove('translate-y-0', 'opacity-100');
      successToast.classList.add('translate-y-12', 'opacity-0', 'pointer-events-none');
    }
  }

  closeToastBtn?.addEventListener('click', dismissToast);

  // Form Reset
  resetFormBtn?.addEventListener('click', () => {
    if (confirm('Are you sure you want to discard all form inputs?')) {
      uploadForm.reset();
      if (modulesList) {
        modulesList.innerHTML = '';
      }
      moduleIndex = 0;
      extractedCreatorLogo = '';
      extractedChannelId = '';
      extractedSubscribers = '';
      extractedViews = 12450;
      if (authorAvatarPreview) authorAvatarPreview.classList.add('hidden');
      if (authorAvatarStatus) authorAvatarStatus.textContent = '';
      // Re-create default one module row
      createModuleRow();
      updateCounters();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  // Form Submit
  uploadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const titleVal = (document.getElementById('course-title') as HTMLInputElement).value;
    const ytVal = (document.getElementById('youtube-link') as HTMLInputElement).value;
    const catVal = (document.getElementById('category') as HTMLSelectElement).value;
    const authorVal = (document.getElementById('author') as HTMLInputElement).value;
    const langVal = (document.getElementById('course-language') as HTMLSelectElement).value;
    const overviewVal = overviewInput.value;

    // Collect dynamic modules
    const modules: Array<{ title: string; description: string; videoId: string }> = [];
    const moduleRows = modulesList?.children || [];
    for (let i = 0; i < moduleRows.length; i++) {
      const row = moduleRows[i];
      const titleInput = row.querySelector('.module-title-input') as HTMLInputElement;
      const descInput = row.querySelector('.module-desc-input') as HTMLInputElement;
      const videoInput = row.querySelector('.module-video-input') as HTMLInputElement;
      if (titleInput && descInput) {
        modules.push({
          title: titleInput.value.trim(),
          description: descInput.value.trim(),
          videoId: videoInput ? videoInput.value.trim() : ''
        });
      }
    }

    // Generate clean slug
    const slug = titleVal.toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)+/g, '');

    // Extract Video ID
    function getYoutubeId(url: string) {
      const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
      const match = url.match(regExp);
      return (match && match[2].length === 11) ? match[2] : 'dQw4w9WgXcQ';
    }
    const sampleVideoId = getYoutubeId(ytVal);

    // Dynamic chapters mapping
    const chapters = modules.map(m => {
      let chVideoId = '';
      if (m.videoId) {
        const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
        const match = m.videoId.match(regExp);
        chVideoId = (match && match[2].length === 11) ? match[2] : m.videoId;
      } else {
        chVideoId = sampleVideoId;
      }
      return {
        title: m.title,
        duration: m.description || '15 mins',
        videoId: chVideoId
      };
    });

    // Use manually added tags or fallback to category/General
    const tools = currentTags.length > 0 ? currentTags : [catVal || "General"];

    // Compile into final Firestore course schema
    const coursePayload = {
      id: Date.now(), // Unique numeric id
      slug,
      title: titleVal.trim(),
      description: overviewVal.trim().slice(0, 120) + "...",
      category: catVal,
      language: langVal,
      rating: 5.0,
      votes: 1,
      publishDate: new Date().toISOString().split('T')[0],
      duration: "1h 30m",
      author: authorVal.trim(),
      creatorName: authorVal.trim(),
      creatorLogo: extractedCreatorLogo || "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&q=80&w=120&h=120",
      channelId: extractedChannelId || '',
      creatorSubscribers: extractedSubscribers || '4.2M subscribers',
      views: extractedViews || 12450,
      type: "free",
      sampleVideoId,
      youtubeUrl: ytVal.trim(),
      tools,
      overview: overviewVal.trim(),
      chapters
    };

    console.log("Writing payload to Firestore:", coursePayload);

    if (db) {
      try {
        const docRef = doc(db, "courses", slug);
        await setDoc(docRef, coursePayload);
        console.log("✅ Document successfully written to Firestore!");
        
        // Reset form inputs & modules rows
        uploadForm.reset();
        if (modulesList) {
          modulesList.innerHTML = '';
        }
        extractedCreatorLogo = '';
        extractedChannelId = '';
        extractedSubscribers = '';
        extractedViews = 12450;
        currentTags = [];
        renderTagChips();
        if (authorAvatarPreview) authorAvatarPreview.classList.add('hidden');
        if (authorAvatarStatus) authorAvatarStatus.textContent = '';
        createModuleRow();
        updateCounters();
        
        // Set toast content
        if (successToast) {
          const toastTitle = successToast.querySelector('h3');
          const toastDesc = successToast.querySelector('p');
          if (toastTitle) toastTitle.textContent = "Submission Success";
          if (toastDesc) toastDesc.textContent = `Course '${slug}' has been dynamically catalogued to Firestore.`;
        }

        triggerToast();
      } catch (err) {
        console.error("❌ Firestore Write Failed:", err);
        alert("Failed to write to database: " + (err instanceof Error ? err.message : err));
      }
    } else {
      console.warn("⚠️ Firestore is offline. Simulating local mock success.");
      triggerToast();
    }
  });

  // Language Selector logic
  function getAvailableLanguages() {
    try {
      const raw = localStorage.getItem(LANGS_KEY);
      return raw ? JSON.parse(raw) : ["English", "Hindi"];
    } catch (e) {
      return ["English", "Hindi"];
    }
  }

  function saveAvailableLanguages(langs: string[]) {
    localStorage.setItem(LANGS_KEY, JSON.stringify(langs));
  }

  function populateLanguageSelect() {
    if (!languageSelect) return;
    const langs = getAvailableLanguages();
    const selectedVal = languageSelect.value;
    
    languageSelect.innerHTML = `<option value="" disabled ${selectedVal === "" ? "selected" : ""}>Select Language</option>`;
    langs.forEach((lang: string) => {
      const option = document.createElement('option');
      option.value = lang;
      option.textContent = lang;
      if (lang === selectedVal) option.selected = true;
      languageSelect.appendChild(option);
    });
  }

  addCustomLangBtn?.addEventListener('click', () => {
    customLangContainer?.classList.toggle('hidden');
    if (customLangContainer && !customLangContainer.classList.contains('hidden')) {
      customLangInput?.focus();
    }
  });

  saveCustomLangBtn?.addEventListener('click', () => {
    if (!customLangInput || !languageSelect) return;
    const newLang = customLangInput.value.trim();
    if (!newLang) return;
    
    const langs = getAvailableLanguages();
    if (!langs.includes(newLang)) {
      langs.push(newLang);
      saveAvailableLanguages(langs);
    }
    
    populateLanguageSelect();
    languageSelect.value = newLang;
    customLangInput.value = '';
    customLangContainer?.classList.add('hidden');
  });

  // Extract YouTube channel info
  async function fetchChannelInfo(urlOrId: string) {
    if (!urlOrId || !authorAvatarStatus) return;
    
    authorAvatarStatus.textContent = "⌛ Fetching channel info...";
    authorAvatarStatus.className = "text-[10px] font-mono text-primary animate-pulse";
    
    try {
      const res = await fetch(`/api/youtube-info?url=${encodeURIComponent(urlOrId)}`);
      if (!res.ok) {
        throw new Error('Failed to resolve channel info');
      }
      const data = await res.json();
      
      if (data.channelName) {
        if (authorInput) {
          authorInput.value = data.channelName;
        }
        extractedCreatorLogo = data.creatorLogo;
        extractedChannelId = data.channelId;
        extractedSubscribers = data.subscribers || '4.2M subscribers';
        extractedViews = data.views || 12450;
        
        if (authorAvatarPreview) {
          authorAvatarPreview.src = data.creatorLogo;
          authorAvatarPreview.classList.remove('hidden');
        }
        
        let statusMsg = "✅ Resolved!";
        if (data.subscribers) statusMsg += ` (${data.subscribers})`;
        if (data.views) statusMsg += ` • ${Number(data.views).toLocaleString()} video views`;
        authorAvatarStatus.textContent = statusMsg;
        authorAvatarStatus.className = "text-[10px] font-mono text-green-400";
      } else {
        authorAvatarStatus.textContent = "⚠️ Could not resolve channel info.";
        authorAvatarStatus.className = "text-[10px] font-mono text-mute";
      }
    } catch (e) {
      console.warn("Failed to fetch channel info:", e);
      authorAvatarStatus.textContent = "❌ Failed to fetch channel details.";
      authorAvatarStatus.className = "text-[10px] font-mono text-red-400";
    }
  }

  // Trigger when youtube-link value changes
  youtubeLinkInput?.addEventListener('change', () => {
    const val = youtubeLinkInput.value.trim();
    if (val) {
      const isPlaylist = val.includes('playlist?list=') || val.startsWith('PL');
      if (isPlaylist) {
        if (authorAvatarStatus) {
          authorAvatarStatus.textContent = "⌛ Playlist detected. Please enter video ID in Module 1 to load channel info.";
          authorAvatarStatus.className = "text-[10px] font-mono text-primary";
        }
      } else {
        fetchChannelInfo(val);
      }
    }
  });

  // Also hook into first module row's video input changes
  modulesList?.addEventListener('input', (e) => {
    const target = e.target as HTMLInputElement;
    if (target && target.classList.contains('module-video-input')) {
      const row = target.closest('[id^="module-row-"]');
      if (row) {
        const rows = Array.from(modulesList.children);
        const index = rows.indexOf(row);
        if (index === 0) {
          const val = target.value.trim();
          const mainUrlVal = youtubeLinkInput?.value.trim() || '';
          const isMainPlaylist = mainUrlVal.includes('playlist?list=') || mainUrlVal.startsWith('PL');
          if (val && (isMainPlaylist || !mainUrlVal)) {
            fetchChannelInfo(val);
          }
        }
      }
    }
  });

  // Initialization
  checkSession();
  renderCategoryManager();
  populateLanguageSelect();
  // Start with 1 default module row if empty
  if (modulesList && modulesList.children.length === 0) {
    createModuleRow();
  }
  updateCounters();
</script>
