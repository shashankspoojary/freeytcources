---
import Layout from '../../layouts/Layout.astro';

const title = "Submitted Courses Directory - Admin Console";
const description = "Manage, view, and search all cataloged and submitted courses.";
---

<Layout title={title} description={description} activePage="admin" hideSidebar={true}>

  <main class="max-w-6xl mx-auto px-6 py-12 md:py-16 flex flex-col items-center justify-center min-h-[calc(100vh-140px)]">
    
    <!-- Lock Screen / Passcode Entry -->
    <div id="lock-screen" class="w-full max-w-md bg-canvas border border-hairline rounded-md p-8 text-center transition-all duration-300 transform scale-100 opacity-100">
      <div class="h-16 w-16 mx-auto mb-6 rounded-full bg-canvas-soft border border-hairline flex items-center justify-center text-primary">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
      </div>
      
      <div class="inline-block font-mono text-[10px] text-primary uppercase tracking-[2.52px] mb-3 bg-primary/10 px-2.5 py-1 rounded-pill border border-primary/20">
        Access Restricted
      </div>
      
      <h1 class="text-2xl font-light text-ink-strong tracking-tight mb-3">Admin Lockscreen</h1>
      <p class="text-sm text-body mb-8 font-light leading-relaxed">
        Authentication required. Enter the administrative passcode to access the submitted courses directory.
      </p>

      <form id="passcode-form" class="space-y-4 text-left">
        <div>
          <label for="passcode" class="block text-xs font-mono uppercase tracking-wider text-mute mb-2">Security Access Code</label>
          <input 
            type="password" 
            id="passcode" 
            placeholder="Hint: admin123" 
            class="w-full bg-canvas-soft border border-hairline text-ink rounded-sm px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder-mute/40"
            required
          />
          <p id="passcode-error" class="hidden text-xs text-red-500 mt-2 font-mono">❌ Invalid passcode. Access denied.</p>
        </div>

        <button 
          type="submit" 
          class="w-full bg-primary text-on-primary font-mono uppercase text-sm font-bold tracking-wider py-3.5 px-4 rounded-sm hover:bg-primary-soft transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-canvas cursor-pointer"
        >
          Unlock Directory
        </button>
      </form>
    </div>

    <!-- Admin Directory Console (Hidden Initially) -->
    <div id="admin-console" class="hidden w-full space-y-8 opacity-0 transform translate-y-4 transition-all duration-500">
      
      <!-- Console Header -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 border-b border-hairline pb-6">
        <div>
          <div class="inline-block font-mono text-[10px] text-primary uppercase tracking-[2.52px] mb-2 bg-primary/10 px-2.5 py-1 rounded-pill border border-primary/20">
            Secure Admin Session Active
          </div>
          <h1 class="text-3xl font-light text-ink-strong tracking-[-0.65px]">Submitted Courses Directory</h1>
          <p class="text-sm text-body font-light mt-1">
            Search, review, and manage all cataloged courses stored in Firestore.
          </p>
        </div>
        
        <div class="flex items-center gap-3">
          <a 
            href="/admin/upload" 
            class="text-xs font-mono uppercase border border-primary/50 text-primary hover:bg-primary hover:text-on-primary px-3.5 py-2.5 rounded-sm transition-all flex items-center gap-2 cursor-pointer font-bold"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add New Course
          </a>

          <button 
            id="lock-console-btn" 
            class="text-xs font-mono uppercase border border-hairline hover:border-red-500/50 hover:text-red-400 text-body px-3.5 py-2.5 rounded-sm transition-all flex items-center gap-2 cursor-pointer"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 00-2 2z" />
            </svg>
            Lock Console
          </button>
        </div>
      <!-- Category Management Card -->
      <div class="bg-canvas-soft border border-hairline rounded-md p-6 space-y-4">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 border-b border-hairline/40 pb-3">
          <div>
            <h2 class="text-sm font-mono uppercase tracking-wider text-ink-strong font-semibold flex items-center gap-2">
              <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 11h.01M7 15h.01M11 7h8M11 11h8M11 15h8" />
              </svg>
              Category Manager
            </h2>
            <p class="text-xs text-body font-light mt-0.5">Type to add new categories or click ✕ to remove existing ones.</p>
          </div>
          <span class="text-xs font-mono text-mute">
            Total Categories: <span id="admin-cat-count" class="text-primary font-bold">0</span>
          </span>
        </div>

        <!-- Add Category Form Row -->
        <div class="space-y-2">
          <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 max-w-lg">
            <input 
              type="text" 
              id="admin-new-category-input" 
              placeholder="Type new category name (e.g. Data Science)..." 
              class="flex-1 bg-canvas border border-hairline text-ink rounded-sm px-3.5 py-2 text-xs font-mono focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20 transition-all placeholder:text-mute/40"
            />
            <button 
              type="button" 
              id="admin-add-category-btn" 
              class="bg-primary text-on-primary font-mono text-xs uppercase font-bold px-4 py-2 rounded-sm hover:bg-primary-soft transition-colors cursor-pointer shrink-0 flex items-center justify-center gap-1.5 shadow-sm"
            >
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              Add Category
            </button>
          </div>
          <p id="admin-cat-error" class="text-xs font-mono text-red-400 hidden"></p>
        </div>

        <!-- Category Chips -->
        <div class="pt-1">
          <div class="text-[11px] font-mono uppercase text-mute mb-2 font-semibold">Active Catalog Categories:</div>
          <div id="admin-categories-chips" class="flex flex-wrap gap-2">
            <!-- Dynamically populated chips with remove buttons -->
          </div>
        </div>
      </div>

      <!-- Submitted Courses Table Container -->
      <div class="bg-canvas-soft border border-hairline rounded-md p-6 space-y-6">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-hairline/40 pb-4">
          <div class="flex items-center gap-2">
            <h2 class="text-sm font-mono uppercase tracking-wider text-ink-strong font-semibold">Cataloged Submissions Index</h2>
          </div>
          <span class="text-xs font-mono text-mute">
            Total Courses: <span id="total-courses-count" class="text-primary font-bold">0</span>
          </span>
        </div>

        <!-- Admin Search Bar -->
        <div class="relative">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 h-4 w-4 text-mute pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="admin-search-input"
            placeholder="Search courses by title, category, language, or author..."
            class="w-full bg-canvas border border-hairline rounded-sm py-3 pl-10 pr-4 text-xs font-mono text-ink placeholder:text-mute/60 focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20 transition-all"
          />
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-xs font-mono text-body">
            <thead>
              <tr class="border-b border-hairline/60 text-mute uppercase tracking-wider text-[11px]">
                <th class="py-3 font-semibold pr-4">Title</th>
                <th class="py-3 font-semibold pr-4 hidden md:table-cell">Language</th>
                <th class="py-3 font-semibold pr-4 hidden md:table-cell">Category</th>
                <th class="py-3 font-semibold pr-4 hidden sm:table-cell">Author</th>
                <th class="py-3 font-semibold text-right">Action</th>
              </tr>
            </thead>
            <tbody id="admin-courses-list" class="divide-y divide-hairline/30">
              <tr id="admin-courses-loading">
                <td colspan="5" class="py-8 text-center text-mute font-light">Loading database index...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>

  </main>

  <!-- Success Toast Alert Component -->
  <div 
    id="success-toast" 
    class="fixed bottom-6 right-6 z-50 bg-canvas border border-hairline rounded-md p-4 shadow-2xl max-w-sm flex gap-3 transform translate-y-12 opacity-0 pointer-events-none transition-all duration-300 border-l-4 border-l-primary"
  >
    <div class="h-8 w-8 rounded-full bg-primary/10 border border-primary/20 text-primary flex items-center justify-center shrink-0">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <div>
      <h3 class="text-sm font-mono uppercase tracking-wider text-ink-strong font-semibold">Operation Success</h3>
      <p class="text-xs text-body font-light mt-0.5 leading-relaxed">
        The database request completed successfully.
      </p>
    </div>
    <button 
      id="close-toast-btn"
      class="text-mute hover:text-ink transition-colors ml-2 self-start cursor-pointer focus:outline-none bg-transparent border-none"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Custom Delete Confirmation Modal Component -->
  <div 
    id="delete-confirm-modal" 
    class="fixed inset-0 z-50 flex items-center justify-center bg-canvas/60 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300 hidden"
  >
    <div id="delete-modal-card" class="bg-canvas border border-hairline rounded-md p-6 max-w-sm w-full mx-4 shadow-2xl space-y-6 transform scale-95 transition-all duration-300">
      <div class="flex items-center gap-3 text-red-500">
        <div class="h-10 w-10 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center shrink-0">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <h3 class="text-sm font-mono uppercase tracking-wider font-semibold">Confirm Deletion</h3>
      </div>
      
      <p class="text-xs text-body font-light leading-relaxed">
        Are you sure you want to permanently delete <span id="delete-course-title-display" class="font-semibold text-ink-strong">this course</span>? This action cannot be undone.
      </p>
      
      <div class="flex justify-end gap-3 pt-2">
        <button 
          id="cancel-delete-btn" 
          type="button" 
          class="px-4 py-2 bg-canvas border border-hairline hover:border-ink/40 text-ink text-xs font-mono uppercase rounded-sm transition-colors cursor-pointer"
        >
          Cancel
        </button>
        <button 
          id="confirm-delete-btn" 
          type="button" 
          class="px-4 py-2 bg-red-500 text-white hover:bg-red-600 text-xs font-mono uppercase font-bold rounded-sm transition-colors cursor-pointer shadow-md"
        >
          Delete Course
        </button>
      </div>
    </div>
  </div>

  <script>
    import { db } from '../../lib/firebase.js';
    import { collection, getDocs, doc, deleteDoc } from 'firebase/firestore';

    const lockScreen = document.getElementById('lock-screen');
    const adminConsole = document.getElementById('admin-console');
    const passcodeForm = document.getElementById('passcode-form') as HTMLFormElement;
    const passcodeField = document.getElementById('passcode') as HTMLInputElement;
    const passcodeError = document.getElementById('passcode-error');
    const lockConsoleBtn = document.getElementById('lock-console-btn');
    const searchInput = document.getElementById('admin-search-input') as HTMLInputElement;

    // Toast
    const successToast = document.getElementById('success-toast');
    const closeToastBtn = document.getElementById('close-toast-btn');

    // Delete Modal
    const deleteConfirmModal = document.getElementById('delete-confirm-modal');
    const deleteModalCard = document.getElementById('delete-modal-card');
    const deleteCourseTitleDisplay = document.getElementById('delete-course-title-display');
    const cancelDeleteBtn = document.getElementById('cancel-delete-btn');
    const confirmDeleteBtn = document.getElementById('confirm-delete-btn');
    let slugToDelete = '';

    const AUTH_KEY = 'freeytcourses_admin_auth';
    let allFetchedCourses: any[] = [];

    function checkSession() {
      const isAuthed = localStorage.getItem(AUTH_KEY) === 'true';
      if (isAuthed) {
        revealConsole();
      }
    }

    function revealConsole() {
      lockScreen?.classList.add('opacity-0', 'scale-95');
      setTimeout(() => {
        lockScreen?.classList.add('hidden');
        adminConsole?.classList.remove('hidden');
        loadCourses();
        setTimeout(() => {
          adminConsole?.classList.add('opacity-100', 'translate-y-0');
        }, 50);
      }, 300);
    }

    function hideConsole() {
      adminConsole?.classList.remove('opacity-100', 'translate-y-0');
      setTimeout(() => {
        adminConsole?.classList.add('hidden');
        lockScreen?.classList.remove('hidden');
        setTimeout(() => {
          lockScreen?.classList.remove('opacity-0', 'scale-95');
        }, 50);
      }, 300);
      localStorage.removeItem(AUTH_KEY);
      if (passcodeField) passcodeField.value = '';
      passcodeError?.classList.add('hidden');
    }

    // Handle Passcode Unlock
    passcodeForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      if (passcodeField.value === 'admin123') {
        localStorage.setItem(AUTH_KEY, 'true');
        passcodeError?.classList.add('hidden');
        revealConsole();
      } else {
        passcodeError?.classList.remove('hidden');
        passcodeField.classList.add('border-red-500');
        setTimeout(() => {
          passcodeField.classList.remove('border-red-500');
        }, 1000);
      }
    });

    lockConsoleBtn?.addEventListener('click', hideConsole);

    const totalCountEl = document.getElementById('total-courses-count');

    async function loadCourses() {
      const adminCoursesList = document.getElementById('admin-courses-list');
      if (!adminCoursesList) return;

      adminCoursesList.innerHTML = `
        <tr id="admin-courses-loading">
          <td colspan="5" class="py-8 text-center text-mute font-light">Loading database index...</td>
        </tr>
      `;

      if (!db) {
        adminCoursesList.innerHTML = `
          <tr>
            <td colspan="5" class="py-8 text-center text-red-400 font-light">Firestore database offline. Running in mock mode.</td>
          </tr>
        `;
        return;
      }

      try {
        const querySnapshot = await getDocs(collection(db, "courses"));
        allFetchedCourses = [];
        querySnapshot.forEach((docSnap) => {
          allFetchedCourses.push({ id: docSnap.id, ...docSnap.data() });
        });

        // Sort by numerical id descending (newer first)
        allFetchedCourses.sort((a, b) => {
          const idA = Number(a.id) || 0;
          const idB = Number(b.id) || 0;
          return idB - idA;
        });

        renderCoursesTable(allFetchedCourses);
      } catch (err) {
        console.error("❌ Failed to load courses for admin panel:", err);
        adminCoursesList.innerHTML = `
          <tr>
            <td colspan="5" class="py-8 text-center text-red-400 font-light">Failed to retrieve index: ${err instanceof Error ? err.message : err}</td>
          </tr>
        `;
      }
    }

    function renderCoursesTable(courses: any[]) {
      const adminCoursesList = document.getElementById('admin-courses-list');
      if (!adminCoursesList) return;

      if (totalCountEl) totalCountEl.textContent = String(courses.length);

      if (courses.length === 0) {
        adminCoursesList.innerHTML = `
          <tr>
            <td colspan="5" class="py-8 text-center text-mute font-light">No courses found matching search criteria.</td>
          </tr>
        `;
        return;
      }

      adminCoursesList.innerHTML = '';
      courses.forEach((course) => {
        const row = document.createElement('tr');
        row.className = "hover:bg-canvas-soft/45 transition-colors border-b border-hairline/20";
        row.id = `course-row-${course.slug}`;

        row.innerHTML = `
          <td class="py-3.5 pr-4 text-ink-strong font-medium truncate max-w-[200px] md:max-w-xs" title="${course.title}">
            <a href="/courses/${course.slug}" class="hover:text-primary transition-colors">${course.title}</a>
          </td>
          <td class="py-3.5 pr-4 hidden md:table-cell text-mute font-mono text-[11px]">${course.language || 'English'}</td>
          <td class="py-3.5 pr-4 hidden md:table-cell text-mute">${course.category || 'N/A'}</td>
          <td class="py-3.5 pr-4 hidden sm:table-cell text-mute">${course.author || 'N/A'}</td>
          <td class="py-3.5 text-right">
            <button 
              type="button" 
              class="delete-course-btn text-xs font-mono uppercase text-red-500 hover:text-red-400 border border-red-500/20 hover:border-red-500/50 px-2.5 py-1 rounded-sm bg-red-500/5 transition-all cursor-pointer"
              data-slug="${course.slug}"
              data-title="${course.title}"
            >
              Delete
            </button>
          </td>
        `;

        adminCoursesList.appendChild(row);
      });

      // Bind delete button listeners
      adminCoursesList.querySelectorAll('.delete-course-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const button = e.currentTarget as HTMLButtonElement;
          const slug = button.getAttribute('data-slug');
          const title = button.getAttribute('data-title');

          if (slug && title) {
            slugToDelete = slug;
            if (deleteCourseTitleDisplay) {
              deleteCourseTitleDisplay.textContent = `"${title}"`;
            }
            showDeleteModal();
          }
        });
      });
    }

    // Live search filter listener
    searchInput?.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      if (!q) {
        renderCoursesTable(allFetchedCourses);
        return;
      }

      const filtered = allFetchedCourses.filter((course) => {
        const title = (course.title || '').toLowerCase();
        const category = (course.category || '').toLowerCase();
        const language = (course.language || '').toLowerCase();
        const author = (course.author || course.creatorName || '').toLowerCase();
        return title.includes(q) || category.includes(q) || language.includes(q) || author.includes(q);
      });

      renderCoursesTable(filtered);
    });

    async function deleteCourse(slug: string) {
      if (!db) return;
      try {
        const docRef = doc(db, "courses", slug);
        await deleteDoc(docRef);
        console.log(`✅ Document '${slug}' successfully deleted from Firestore.`);
        
        allFetchedCourses = allFetchedCourses.filter(c => c.slug !== slug);
        renderCoursesTable(allFetchedCourses);

        if (successToast) {
          const toastTitle = successToast.querySelector('h3');
          const toastDesc = successToast.querySelector('p');
          if (toastTitle) toastTitle.textContent = "Deletion Success";
          if (toastDesc) toastDesc.textContent = `Course '${slug}' was permanently removed from database.`;
          triggerToast();
        }
      } catch (err) {
        console.error("❌ Failed to delete course:", err);
        alert("Failed to delete course: " + (err instanceof Error ? err.message : err));
      }
    }

    function showDeleteModal() {
      if (!deleteConfirmModal || !deleteModalCard) return;
      deleteConfirmModal.classList.remove('hidden');
      setTimeout(() => {
        deleteConfirmModal.classList.remove('opacity-0', 'pointer-events-none');
        deleteConfirmModal.classList.add('opacity-100', 'pointer-events-auto');
        deleteModalCard.classList.remove('scale-95');
        deleteModalCard.classList.add('scale-100');
      }, 50);
    }

    function hideDeleteModal() {
      if (!deleteConfirmModal || !deleteModalCard) return;
      deleteConfirmModal.classList.remove('opacity-100', 'pointer-events-auto');
      deleteConfirmModal.classList.add('opacity-0', 'pointer-events-none');
      deleteModalCard.classList.remove('scale-100');
      deleteModalCard.classList.add('scale-95');
      setTimeout(() => {
        deleteConfirmModal.classList.add('hidden');
        slugToDelete = '';
      }, 300);
    }

    cancelDeleteBtn?.addEventListener('click', hideDeleteModal);
    confirmDeleteBtn?.addEventListener('click', () => {
      if (slugToDelete) {
        const slug = slugToDelete;
        hideDeleteModal();
        deleteCourse(slug);
      }
    });

    function triggerToast() {
      if (!successToast) return;
      successToast.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-12');
      successToast.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');

      setTimeout(() => {
        successToast.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
        successToast.classList.add('opacity-0', 'pointer-events-none', 'translate-y-12');
      }, 4000);
    }

    closeToastBtn?.addEventListener('click', () => {
      if (!successToast) return;
      successToast.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      successToast.classList.add('opacity-0', 'pointer-events-none', 'translate-y-12');
    });

    // Category Manager Integration in Admin Console
    const DEFAULT_CATEGORIES = ["AI Engineering", "Video Editing", "Coding Skills"];
    const CAT_STORAGE_KEY = 'freeyt_categories';

    function getAdminCategories(): string[] {
      try {
        const raw = localStorage.getItem(CAT_STORAGE_KEY);
        const parsed = raw ? JSON.parse(raw) : null;
        if (Array.isArray(parsed) && parsed.length > 0) return parsed;
      } catch (e) {}
      localStorage.setItem(CAT_STORAGE_KEY, JSON.stringify(DEFAULT_CATEGORIES));
      return DEFAULT_CATEGORIES;
    }

    function saveAdminCategories(cats: string[]) {
      localStorage.setItem(CAT_STORAGE_KEY, JSON.stringify(cats));
      window.dispatchEvent(new CustomEvent('categoriesChanged', { detail: cats }));
    }

    const adminCatInput = document.getElementById('admin-new-category-input') as HTMLInputElement;
    const adminAddCatBtn = document.getElementById('admin-add-category-btn');
    const adminCatChipsContainer = document.getElementById('admin-categories-chips');
    const adminCatCountBadge = document.getElementById('admin-cat-count');
    const adminCatErrorMsg = document.getElementById('admin-cat-error');

    function renderAdminCategoryManager() {
      const cats = getAdminCategories();
      
      if (adminCatCountBadge) {
        adminCatCountBadge.textContent = String(cats.length);
      }

      if (adminCatChipsContainer) {
        adminCatChipsContainer.innerHTML = '';
        cats.forEach(cat => {
          const chip = document.createElement('div');
          chip.className = 'inline-flex items-center gap-1.5 px-3 py-1 bg-canvas border border-hairline hover:border-primary/50 text-ink rounded-sm text-xs font-mono transition-colors group shadow-sm';
          chip.innerHTML = `
            <span>${cat}</span>
            <button type="button" class="admin-remove-cat-btn text-mute hover:text-red-400 focus:outline-none cursor-pointer text-xs font-bold ml-1 transition-colors" data-category="${cat}" title="Remove category">&times;</button>
          `;

          chip.querySelector('.admin-remove-cat-btn')?.addEventListener('click', (e) => {
            e.stopPropagation();
            removeAdminCategory(cat);
          });

          adminCatChipsContainer.appendChild(chip);
        });
      }
    }

    function addAdminCategory() {
      if (!adminCatInput) return;
      const rawVal = adminCatInput.value.trim();
      if (!rawVal) {
        showAdminCatError("Please enter a category name.");
        return;
      }

      const currentCats = getAdminCategories();
      const exists = currentCats.some(c => c.toLowerCase() === rawVal.toLowerCase());
      if (exists) {
        showAdminCatError(`Category '${rawVal}' already exists.`);
        return;
      }

      hideAdminCatError();
      const updated = [...currentCats, rawVal];
      saveAdminCategories(updated);
      renderAdminCategoryManager();
      adminCatInput.value = '';

      if (successToast) {
        const toastTitle = successToast.querySelector('h3');
        const toastDesc = successToast.querySelector('p');
        if (toastTitle) toastTitle.textContent = "Category Added";
        if (toastDesc) toastDesc.textContent = `New category '${rawVal}' was added to catalog index.`;
        triggerToast();
      }
    }

    function removeAdminCategory(catToRemove: string) {
      const currentCats = getAdminCategories();
      if (currentCats.length <= 1) {
        showAdminCatError("At least one category must remain.");
        return;
      }

      hideAdminCatError();
      const updated = currentCats.filter(c => c !== catToRemove);
      saveAdminCategories(updated);
      renderAdminCategoryManager();

      if (successToast) {
        const toastTitle = successToast.querySelector('h3');
        const toastDesc = successToast.querySelector('p');
        if (toastTitle) toastTitle.textContent = "Category Removed";
        if (toastDesc) toastDesc.textContent = `Category '${catToRemove}' was removed from catalog index.`;
        triggerToast();
      }
    }

    function showAdminCatError(msg: string) {
      if (adminCatErrorMsg) {
        adminCatErrorMsg.textContent = msg;
        adminCatErrorMsg.classList.remove('hidden');
      }
    }

    function hideAdminCatError() {
      if (adminCatErrorMsg) {
        adminCatErrorMsg.classList.add('hidden');
      }
    }

    adminAddCatBtn?.addEventListener('click', addAdminCategory);
    adminCatInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        addAdminCategory();
      }
    });

    window.addEventListener('categoriesChanged', renderAdminCategoryManager);
    window.addEventListener('storage', (e) => {
      if (e.key === CAT_STORAGE_KEY) renderAdminCategoryManager();
    });

    renderAdminCategoryManager();
    checkSession();
  </script>
</Layout>
