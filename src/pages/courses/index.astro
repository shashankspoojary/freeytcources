---
import Layout from '../../layouts/Layout.astro';
import { getAllCourses, getYoutubeThumbnail, getCreatorSlug } from '../../lib/firebase.js';

const courses = await getAllCourses();

// Dynamically compute unique languages
const languages = Array.from(new Set(courses.map(c => c.language || "English").filter(Boolean)));

const title = "Courses Directory - Filter & Browse YouTube Courses";
const description = "Filter, search, and sort high-quality curated YouTube courses for AI Engineering, Video Editing, and Coding Skills.";
---

<Layout title={title} description={description} activePage="courses">
  <main id="courses-section" class="max-w-6xl mx-auto px-6 py-8 md:py-12">
    <!-- Top Header -->
    <div class="mb-8 pb-4 border-b border-hairline flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div>
        <h1 class="text-2xl font-light text-ink-strong tracking-tight flex items-center gap-3">
          Courses Directory
          <span class="text-xs font-mono bg-primary/15 text-primary border border-primary/30 px-2.5 py-0.5 rounded-full font-bold">
            {courses.length} courses
          </span>
        </h1>
        <p class="text-xs font-mono text-mute mt-1">Structured learning modules filtered by skills, language, and ratings.</p>
      </div>
    </div>

    <!-- Google AdSense Responsive Display Unit (Courses Directory Banner) -->
    <div class="mb-10 bg-canvas-soft/60 border border-hairline/60 rounded-md p-4 text-center">
      <div class="text-[10px] font-mono uppercase tracking-widest text-mute mb-2">Advertisement</div>
      <ins class="adsbygoogle block w-full overflow-hidden text-center min-h-[90px]"
           style="display:block"
           data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
           data-ad-slot="4567890123"
           data-ad-format="auto"
           data-full-width-responsive="true">
        <!-- Dev Placeholder Visual -->
        <div class="border border-dashed border-hairline rounded p-4 flex items-center justify-center gap-3 bg-canvas/40">
          <svg class="h-5 w-5 text-primary/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-xs font-mono text-mute">Google AdSense Responsive Unit Placeholder (Courses Directory Banner)</span>
        </div>
      </ins>
    </div>

    <!-- User Retention: Continue Learning Section -->
    <section id="continue-learning-section" class="hidden mb-10 bg-canvas border border-hairline rounded-md p-6">
      <div class="flex items-center gap-2 mb-4">
        <svg class="h-4 w-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h2 class="text-xs font-mono uppercase tracking-[2.52px] text-ink-strong font-semibold">Continue Learning</h2>
      </div>
      <div id="continue-learning-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Dynamically populated -->
      </div>
    </section>

    <!-- Filters & Sort Controls Bar (Dropdown Selects) -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 p-4 bg-canvas-soft/40 border border-hairline rounded-md">
      <div class="flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center gap-4 w-full md:w-auto">
        
        <!-- Skill / Category Filter Dropdown -->
        <div class="flex items-center gap-2">
          <label for="skill-filter-select" class="text-xs font-mono uppercase tracking-wider text-mute font-semibold shrink-0">Filter Skill:</label>
          <div class="relative flex-1 sm:flex-initial">
            <select 
              id="skill-filter-select" 
              class="w-full sm:w-48 appearance-none bg-canvas border border-hairline text-ink rounded-sm pl-3.5 pr-9 py-2 text-xs font-mono focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all cursor-pointer"
            >
              <option value="All" selected>All Courses</option>
              <option value="AI Engineering">AI Engineering</option>
              <option value="Video Editing">Video Editing</option>
              <option value="Coding Skills">Coding Skills</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2.5 text-mute">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
        </div>

        <!-- Language Filter Dropdown -->
        <div class="flex items-center gap-2">
          <label for="language-filter-select" class="text-xs font-mono uppercase tracking-wider text-mute font-semibold shrink-0">Language:</label>
          <div class="relative flex-1 sm:flex-initial">
            <select 
              id="language-filter-select" 
              class="w-full sm:w-44 appearance-none bg-canvas border border-hairline text-ink rounded-sm pl-3.5 pr-9 py-2 text-xs font-mono focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all cursor-pointer"
            >
              <option value="All" selected>All Languages</option>
              {languages.map((lang) => (
                <option value={lang}>{lang}</option>
              ))}
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2.5 text-mute">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
        </div>

      </div>

      <!-- Sort By Dropdown -->
      <div class="flex items-center gap-2 w-full md:w-auto justify-start md:justify-end">
        <label for="sort-filter-select" class="text-xs font-mono uppercase tracking-wider text-mute font-semibold shrink-0">Sort By:</label>
        <div class="relative flex-1 sm:flex-initial">
          <select 
            id="sort-filter-select" 
            class="w-full sm:w-40 appearance-none bg-canvas border border-hairline text-ink rounded-sm pl-3.5 pr-9 py-2 text-xs font-mono focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all cursor-pointer"
          >
            <option value="latest" selected>Latest</option>
            <option value="popular">Most Popular</option>
            <option value="top-rated">Top Rated</option>
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2.5 text-mute">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Course Cards Grid -->
    <div id="course-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {courses.map((course) => (
        <article 
          class="course-card group bg-canvas-soft border border-hairline rounded-md flex flex-col justify-between hover:border-primary/45 transition-all duration-300 relative overflow-hidden h-full cursor-pointer"
          data-id={course.id}
          data-category={course.category}
          data-language={course.language || 'English'}
          data-views={course.views}
          data-votes={course.votes}
          data-rating={course.rating}
          data-date={course.publishDate}
          data-creator={course.creatorName}
          data-slug={course.slug}
        >
          <!-- Prominent Thumbnail & Promo Badge -->
          <div class="relative aspect-video w-full overflow-hidden border-b border-hairline bg-canvas">
            <img 
              src={getYoutubeThumbnail(course.sampleVideoId)} 
              alt={`${course.title} thumbnail`} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <!-- Always-Visible Watch Later Button -->
            <button 
              type="button" 
              class="watch-later-toggle-btn absolute top-2.5 left-2.5 z-30 bg-canvas/95 hover:bg-primary hover:text-on-primary text-ink px-2.5 py-1 rounded-sm transition-all shadow-md focus:outline-none cursor-pointer border border-hairline hover:border-primary flex items-center gap-1.5 text-[11px] font-mono"
              data-slug={course.slug}
              title="Save to Watch Later"
            >
              <svg class="h-3.5 w-3.5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="wl-label pointer-events-none">Watch later</span>
            </button>
            <span class={`absolute top-3 right-3 text-[10px] font-mono uppercase tracking-wider px-2.5 py-0.5 rounded-sm font-semibold shadow-md ${course.type === 'paid' ? 'bg-amber-400 text-on-primary border border-amber-500/20' : 'bg-primary text-on-primary border border-primary-soft/20'}`}>
              {course.type}
            </span>
            <!-- Modules Count Overlay Badge -->
            <div class="absolute bottom-2.5 right-2.5 z-20 bg-canvas/90 backdrop-blur-sm text-ink-strong border border-hairline px-2 py-0.5 rounded-sm text-[10px] font-mono flex items-center gap-1.5 shadow-md">
              <svg class="h-3 w-3 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
              <span>{course.chapters?.length || 0} Modules</span>
            </div>
          </div>

          <!-- Card Content -->
          <div class="p-6 flex flex-col justify-between flex-grow">
            <div>
              <div class="flex justify-between items-center mb-3">
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px] font-mono uppercase bg-canvas border border-hairline px-2.5 py-0.5 rounded-pill text-body">
                    {course.category}
                  </span>
                  <span class="text-[10px] font-mono uppercase bg-canvas border border-hairline/85 px-2 py-0.5 rounded-sm text-mute">
                    {course.language || 'English'}
                  </span>
                </div>
                <span class="text-xs font-mono text-mute">{course.duration}</span>
              </div>

              <h2 class="text-lg font-semibold text-ink-strong mb-2.5 group-hover:text-primary transition-colors line-clamp-2 leading-snug">
                <a href={`/courses/${course.slug}`} class="focus:outline-none after:absolute after:inset-0">
                  {course.title}
                </a>
              </h2>

              <a href={`/creators/${getCreatorSlug(course.creatorName)}`} class="flex items-center gap-2 mb-4 hover:text-primary transition-colors group/creator shrink-0 relative z-30">
                <img 
                  src={course.creatorLogo} 
                  alt={course.creatorName} 
                  class="h-6 w-6 rounded-full object-cover border border-hairline shrink-0 group-hover/creator:border-primary transition-colors"
                />
                <div class="flex flex-col">
                  <span class="text-xs font-mono text-mute group-hover/creator:text-primary transition-colors leading-none">{course.creatorName}</span>
                  <span class="text-[9px] font-mono text-mute/50 leading-none mt-1">{course.creatorSubscribers || "4.2M subscribers"}</span>
                </div>
              </a>

              <p class="text-xs text-body mb-5 line-clamp-2 leading-relaxed">
                {course.description}
              </p>
            </div>

            <div>
              <div class="pt-3.5 border-t border-hairline flex justify-between items-center text-[11px] font-mono text-mute">
                <div class="flex items-center gap-1">
                  <svg class="h-3.5 w-3.5 text-primary fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                  <span class="text-ink font-semibold">{course.rating.toFixed(1)}</span>
                  <span class="text-[10px]">({course.votes})</span>
                </div>
                
                <div class="flex items-center gap-1">
                  <span class="text-ink font-semibold">{course.views.toLocaleString()}</span>
                  <span class="text-[10px]">views</span>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty state card -->
    <div id="empty-state" class="hidden text-center p-12 bg-canvas-soft border border-hairline border-dashed rounded-md my-12 max-w-xl mx-auto">
      <svg class="mx-auto h-12 w-12 text-mute mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="text-lg font-semibold text-ink mb-1 font-mono uppercase tracking-wider">No Courses Found</h3>
      <p class="text-sm text-body">No curated courses match the selected search parameters or skill categories.</p>
    </div>

    <div id="courses-data" data-courses={JSON.stringify(courses)} class="hidden"></div>
  </main>

  <script>
    const skillSelect = document.getElementById('skill-filter-select') as HTMLSelectElement;
    const languageSelect = document.getElementById('language-filter-select') as HTMLSelectElement;
    const sortSelect = document.getElementById('sort-filter-select') as HTMLSelectElement;

    const courseGrid = document.getElementById('course-grid');
    const emptyState = document.getElementById('empty-state');
    
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    let searchQuery = '';
    
    let activeFilter = 'All';
    let activeLanguage = 'All';
    let activeSort = 'latest';

    const coursesDataEl = document.getElementById('courses-data');
    const allCourses = JSON.parse(coursesDataEl?.getAttribute('data-courses') || '[]');

    // Populate skill/category dropdown dynamically from stored categories
    function populateCategoryOptions() {
      if (!skillSelect) return;
      try {
        const raw = localStorage.getItem('freeyt_categories');
        const cats = raw ? JSON.parse(raw) : ["AI Engineering", "Video Editing", "Coding Skills"];
        const cur = activeFilter;

        skillSelect.innerHTML = '<option value="All">All Courses</option>';
        cats.forEach((cat: string) => {
          const opt = document.createElement('option');
          opt.value = cat;
          opt.textContent = cat;
          if (cat === cur) opt.selected = true;
          skillSelect.appendChild(opt);
        });
        if (cats.includes(cur) || cur === 'All') {
          skillSelect.value = cur;
        } else {
          skillSelect.value = 'All';
          activeFilter = 'All';
        }
      } catch (e) {}
    }

    // Read ?q= URL param on page load and pre-fill search input
    const urlParams = new URLSearchParams(window.location.search);
    const initialQuery = urlParams.get('q') || '';
    if (initialQuery && searchInput) {
      searchInput.value = initialQuery;
      searchQuery = initialQuery;
    }

    // Listen for live search input from global HeaderNav search bar
    window.addEventListener('globalSearchInput', ((e: CustomEvent) => {
      searchQuery = e.detail || '';
      applyFiltersAndSort();
    }) as EventListener);

    skillSelect?.addEventListener('change', () => {
      activeFilter = skillSelect.value;
      applyFiltersAndSort();
    });

    languageSelect?.addEventListener('change', () => {
      activeLanguage = languageSelect.value;
      applyFiltersAndSort();
    });

    sortSelect?.addEventListener('change', () => {
      activeSort = sortSelect.value;
      applyFiltersAndSort();
    });

    window.addEventListener('categoriesChanged', () => {
      populateCategoryOptions();
      applyFiltersAndSort();
    });

    window.addEventListener('storage', (e) => {
      if (e.key === 'freeyt_categories') {
        populateCategoryOptions();
        applyFiltersAndSort();
      }
    });

    function getLevenshteinDistance(a: string, b: string): number {
      const matrix: number[][] = [];
      for (let i = 0; i <= b.length; i++) matrix[i] = [i];
      for (let j = 0; j <= a.length; j++) matrix[0][j] = j;
      for (let i = 1; i <= b.length; i++) {
        for (let j = 1; j <= a.length; j++) {
          if (b.charAt(i - 1) === a.charAt(j - 1)) {
            matrix[i][j] = matrix[i - 1][j - 1];
          } else {
            matrix[i][j] = Math.min(
              matrix[i - 1][j - 1] + 1,
              matrix[i][j - 1] + 1,
              matrix[i - 1][j] + 1
            );
          }
        }
      }
      return matrix[b.length][a.length];
    }

    function searchMatch(course: any, query: string): boolean {
      const q = query.toLowerCase().trim();
      if (!q) return true;

      const title = course.title.toLowerCase();
      const creator = course.creatorName.toLowerCase();
      const category = course.category.toLowerCase();
      const description = course.description.toLowerCase();
      const language = (course.language || 'English').toLowerCase();
      const tools = course.tools.map((t: string) => t.toLowerCase()).join(' ');

      if (title.includes(q) || creator.includes(q) || category.includes(q) || description.includes(q) || tools.includes(q) || language.includes(q)) {
        return true;
      }

      const words = q.split(/\s+/).filter(Boolean);
      if (words.length > 1) {
        const combinedText = `${title} ${creator} ${category} ${tools} ${language}`;
        if (words.every(w => combinedText.includes(w))) {
          return true;
        }
      }

      if (q.length >= 3) {
        const courseTokens = [...title.split(/[\s,.-]+/), ...creator.split(/[\s,.-]+/)].filter(t => t.length >= 3);
        for (const token of courseTokens) {
          const dist = getLevenshteinDistance(q, token);
          if (dist <= 1 || (q.length >= 4 && dist <= 2)) {
            return true;
          }
        }
      }

      return false;
    }

    function setFilter(category: string) {
      activeFilter = category;
      if (skillSelect) skillSelect.value = category;
      applyFiltersAndSort();
    }

    function setSort(sortType: string) {
      activeSort = sortType;
      if (sortSelect) sortSelect.value = sortType;
      applyFiltersAndSort();
    }

    function setLanguage(lang: string) {
      activeLanguage = lang;
      if (languageSelect) languageSelect.value = lang;
      applyFiltersAndSort();
    }

    function applyFiltersAndSort() {
      if (!courseGrid) return;
      const cards = Array.from(courseGrid.getElementsByClassName('course-card')) as HTMLElement[];
      const currentQuery = searchQuery || searchInput?.value || '';
      let visibleCount = 0;

      cards.forEach((card) => {
        const cat = card.getAttribute('data-category');
        const lang = card.getAttribute('data-language') || 'English';
        const slug = card.getAttribute('data-slug');
        const course = allCourses.find((c: any) => c.slug === slug);

        const matchesCategory = activeFilter === 'All' || cat === activeFilter;
        const matchesLanguage = activeLanguage === 'All' || lang === activeLanguage;
        const matchesSearch = course ? searchMatch(course, currentQuery) : true;

        if (matchesCategory && matchesLanguage && matchesSearch) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      if (visibleCount === 0) {
        emptyState?.classList.remove('hidden');
        courseGrid.classList.add('hidden');
      } else {
        emptyState?.classList.add('hidden');
        courseGrid.classList.remove('hidden');
      }

      cards.sort((a, b) => {
        if (activeSort === 'latest') {
          const dateA = new Date(a.getAttribute('data-date') || '');
          const dateB = new Date(b.getAttribute('data-date') || '');
          return dateB.getTime() - dateA.getTime();
        } else if (activeSort === 'popular') {
          const viewsA = Number(a.getAttribute('data-views') || 0);
          const viewsB = Number(b.getAttribute('data-views') || 0);
          return viewsB - viewsA;
        } else if (activeSort === 'top-rated') {
          const ratingA = Number(a.getAttribute('data-rating') || 0);
          const votesA = Number(a.getAttribute('data-votes') || 0);
          const ratingB = Number(b.getAttribute('data-rating') || 0);
          const votesB = Number(b.getAttribute('data-votes') || 0);
          const scoreA = ratingA * Math.log10(votesA + 1);
          const scoreB = ratingB * Math.log10(votesB + 1);
          return scoreB - scoreA;
        }
        return 0;
      });

      cards.forEach((card) => {
        courseGrid.appendChild(card);
      });
    }

    function showToast(message: string, actionText = '', actionUrl = '') {
      let container = document.getElementById('toast-container');
      if (!container) {
        container = document.createElement('div');
        container.id = 'toast-container';
        container.className = 'fixed bottom-6 left-6 z-50 flex flex-col gap-2 pointer-events-none';
        document.body.appendChild(container);
      }

      const toast = document.createElement('div');
      toast.className = 'pointer-events-auto bg-canvas-soft border border-primary/50 text-ink px-4 py-3 rounded-md shadow-2xl flex items-center gap-4 text-xs font-mono transition-all duration-300';
      toast.innerHTML = `
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>${message}</span>
        </div>
        ${actionText && actionUrl ? `<a href="${actionUrl}" class="text-primary font-bold hover:underline shrink-0">${actionText} &rarr;</a>` : ''}
      `;

      container.appendChild(toast);

      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateY(10px)';
        setTimeout(() => toast.remove(), 300);
      }, 3500);
    }

    function updateWatchLaterButtons() {
      let wl: string[] = [];
      try {
        const raw = localStorage.getItem('freeyt_watch_later');
        wl = raw ? JSON.parse(raw) : [];
      } catch (e) {
        wl = [];
      }

      document.querySelectorAll('.watch-later-toggle-btn').forEach(btn => {
        const slug = btn.getAttribute('data-slug');
        const label = btn.querySelector('.wl-label');
        if (slug && Array.isArray(wl) && wl.includes(slug)) {
          btn.className = "watch-later-toggle-btn absolute top-2.5 left-2.5 z-30 bg-primary text-on-primary font-bold px-2.5 py-1 rounded-sm transition-all shadow-md focus:outline-none cursor-pointer border border-primary flex items-center gap-1.5 text-[11px] font-mono";
          if (label) label.textContent = "Saved";
          btn.setAttribute('title', 'Saved to Watch Later (Click to remove)');
        } else {
          btn.className = "watch-later-toggle-btn absolute top-2.5 left-2.5 z-30 bg-canvas/95 hover:bg-primary hover:text-on-primary text-ink px-2.5 py-1 rounded-sm transition-all shadow-md focus:outline-none cursor-pointer border border-hairline hover:border-primary flex items-center gap-1.5 text-[11px] font-mono";
          if (label) label.textContent = "Watch later";
          btn.setAttribute('title', 'Save to Watch Later');
        }
      });
    }

    document.querySelectorAll('.watch-later-toggle-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const slug = btn.getAttribute('data-slug');
        if (!slug) return;

        let wl: string[] = [];
        try {
          const raw = localStorage.getItem('freeyt_watch_later');
          wl = raw ? JSON.parse(raw) : [];
        } catch (e) {
          wl = [];
        }

        const isSaved = wl.includes(slug);
        if (isSaved) {
          wl = wl.filter(s => s !== slug);
          showToast('Removed from Watch Later');
        } else {
          wl.push(slug);
          showToast('Saved to Watch Later', 'View Playlist', '/watch-later');
        }

        localStorage.setItem('freeyt_watch_later', JSON.stringify(wl));
        window.dispatchEvent(new Event('watchLaterChanged'));
        updateWatchLaterButtons();
      });
    });

    populateCategoryOptions();
    applyFiltersAndSort();
    updateWatchLaterButtons();
    window.addEventListener('watchLaterChanged', updateWatchLaterButtons);
  </script>
</Layout>
