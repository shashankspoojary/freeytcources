    function applyFiltersAndSort() {
      if (!courseGrid) return;
      const cards = Array.from(courseGrid.getElementsByClassName('course-card')) as HTMLElement[];
      const searchQuery = searchInput?.value || '';
      let visibleCount = 0;

      // 1. Filter by category, language & search query (using upgraded searchMatch logic)
      cards.forEach((card) => {
        const cat = card.getAttribute('data-category');
        const lang = card.getAttribute('data-language') || 'English';
        const slug = card.getAttribute('data-slug');
        const course = allCourses.find((c: any) => c.slug === slug);

        const matchesCategory = activeFilter === 'All' || cat === activeFilter;
        const matchesLanguage = activeLanguage === 'All' || lang === activeLanguage;
        const matchesSearch = course ? searchMatch(course, searchQuery) : true;

        if (matchesCategory && matchesLanguage && matchesSearch) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      // Show/hide empty state
      if (visibleCount === 0) {
        emptyState?.classList.remove('hidden');
        courseGrid.classList.add('hidden');
      } else {
        emptyState?.classList.add('hidden');
        courseGrid.classList.remove('hidden');
      }

      // 2. Sort visible cards
      cards.sort((a, b) => {
        if (activeSort === 'latest') {
          const dateA = new Date(a.getAttribute('data-date') || '');
          const dateB = new Date(b.getAttribute('data-date') || '');
          return dateB.getTime() - dateA.getTime();
        } else if (activeSort === 'popular') {
          const viewsA = Number(a.getAttribute('data-views') || 0);
          const viewsB = Number(b.getAttribute('data-views') || 0);
          return viewsB - viewsA;
        } else if (activeSort === 'top-rated') {
          // Weighted average calculation using rating and logarithmic vote count
          const ratingA = Number(a.getAttribute('data-rating') || 0);
          const votesA = Number(a.getAttribute('data-votes') || 0);
          const ratingB = Number(b.getAttribute('data-rating') || 0);
          const votesB = Number(b.getAttribute('data-votes') || 0);
          
          const scoreA = ratingA * Math.log10(votesA + 1);
          const scoreB = ratingB * Math.log10(votesB + 1);
          
          return scoreB - scoreA;
        }
        return 0;
      });

      // Re-append sorted nodes to the grid DOM container
      cards.forEach((card) => {
        courseGrid.appendChild(card);
      });
    }

    // User Retention: LocalStorage Watch History Engine
    function addToHistory(slug: string) {
      let history: string[] = [];
      try {
        const raw = localStorage.getItem(HISTORY_KEY);
        if (raw) {
          history = JSON.parse(raw);
        }
      } catch (e) {
        console.error(e);
      }

      if (!Array.isArray(history)) {
        history = [];
      }

      // Prepend to history & remove duplicates
      history = history.filter(item => item !== slug);
      history.unshift(slug);

      // Keep only top 4 items
      if (history.length > 4) {
        history = history.slice(0, 4);
      }

      localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
    }

    function renderContinueLearning() {
      const container = document.getElementById('continue-learning-section');
      const grid = document.getElementById('continue-learning-grid');
      if (!container || !grid) return;

      let history: string[] = [];
      try {
        const raw = localStorage.getItem(HISTORY_KEY);
        if (raw) {
          history = JSON.parse(raw);
        }
      } catch (e) {
        console.error(e);
      }

      if (!Array.isArray(history) || history.length === 0) {
        container.classList.add('hidden');
        return;
      }

      grid.innerHTML = '';
      let count = 0;

      history.forEach((slug) => {
        const course = allCourses.find((c: any) => c.slug === slug);
        if (course) {
          count++;
          const thumbnailUrl = `https://img.youtube.com/vi/${course.sampleVideoId}/maxresdefault.jpg`;
          
          const progressKey = `freeyt_progress_${course.slug}`;
          let progressPercent = 0;
          let progressLabel = '';
          try {
            const rawProgress = localStorage.getItem(progressKey);
            if (rawProgress) {
              const progressState = JSON.parse(rawProgress);
              const totalCh = course.chapters ? course.chapters.length : 5;
              const completedCh = Array.isArray(progressState.completedChapters) ? progressState.completedChapters.length : 0;
              progressPercent = totalCh > 0 ? Math.round((completedCh / totalCh) * 100) : 0;
              
              if (completedCh > 0 || Object.keys(progressState.chapterPositions || {}).length > 0) {
                const activeIdx = typeof progressState.lastActiveIndex === 'number' ? progressState.lastActiveIndex : 0;
                const chTitle = course.chapters && course.chapters[activeIdx] ? course.chapters[activeIdx].title : `Lesson ${activeIdx+1}`;
                progressLabel = `${completedCh}/${totalCh} done • Resume: ${chTitle.split(':')[0]}`;
              }
            }
          } catch (err) {
            console.error(err);
          }

          const progressBarHtml = progressPercent > 0 ? `
            <div class="mt-2 space-y-1 overflow-hidden">
              <div class="w-full h-1 bg-canvas border border-hairline rounded-sm overflow-hidden">
                <div class="h-full bg-primary" style="width: ${progressPercent}%"></div>
              </div>
              <div class="flex justify-between items-center text-[9px] font-mono text-mute gap-2">
                <span class="text-primary font-semibold">${progressPercent}% done</span>
                <span class="truncate text-right" title="${progressLabel}">${progressLabel.split('•')[1] || ''}</span>
              </div>
            </div>
          ` : `
            <div class="flex items-center gap-1.5 mt-2">
              <img src="${course.creatorLogo}" class="h-4 w-4 rounded-full border border-hairline object-cover shrink-0" alt="${course.creatorName}" />
              <span class="text-[10px] font-mono text-mute line-clamp-1">${course.creatorName}</span>
            </div>
          `;

          const cardHtml = `
            <div class="group bg-canvas-soft border border-hairline rounded-md p-4 flex gap-4 hover:border-primary/45 transition-all duration-300 relative overflow-hidden">
              <a href="/courses/${course.slug}" class="flex gap-4 flex-grow overflow-hidden">
                <img src="${thumbnailUrl}" class="h-16 w-24 object-cover rounded-sm shrink-0 border border-hairline" alt="${course.title} thumbnail" />
                <div class="flex flex-col justify-between overflow-hidden flex-grow">
                  <div>
                    <span class="text-[9px] font-mono uppercase text-primary tracking-wider">${course.category}</span>
                    <h3 class="text-xs font-semibold text-ink-strong group-hover:text-primary transition-colors line-clamp-1 mt-0.5">${course.title}</h3>
                  </div>
                  ${progressBarHtml}
                </div>
              </a>
              <button 
                type="button" 
                class="cl-remove-btn absolute top-2 right-2 p-1 rounded-sm bg-canvas/80 hover:bg-red-500 text-mute hover:text-white transition-all opacity-0 group-hover:opacity-100 cursor-pointer z-10"
                data-slug="${course.slug}"
                title="Remove from Continue Learning"
              >
                <svg class="h-3 w-3 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          `;
          grid.insertAdjacentHTML('beforeend', cardHtml);
        }
      });

      // Attach remove button listeners
      grid.querySelectorAll('.cl-remove-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const slug = btn.getAttribute('data-slug');
          if (!slug) return;

          try {
            const raw = localStorage.getItem(HISTORY_KEY);
            let hist: string[] = raw ? JSON.parse(raw) : [];
            hist = hist.filter(s => s !== slug);
            localStorage.setItem(HISTORY_KEY, JSON.stringify(hist));
          } catch (err) {
            console.error(err);
          }

          renderContinueLearning();
        });
      });

      if (count > 0) {
        container.classList.remove('hidden');
      } else {
        container.classList.add('hidden');
      }
    }

    function renderCourseGridProgress() {
      document.querySelectorAll('.course-card').forEach((card) => {
        const slug = card.getAttribute('data-slug');
        if (!slug) return;
        
        const progressKey = `freeyt_progress_${slug}`;
        try {
          const rawProgress = localStorage.getItem(progressKey);
          if (rawProgress) {
            const progressState = JSON.parse(rawProgress);
            const course = allCourses.find((c: any) => c.slug === slug);
            if (!course) return;
            const totalCh = course.chapters ? course.chapters.length : 5;
            const completedCh = Array.isArray(progressState.completedChapters) ? progressState.completedChapters.length : 0;
            const progressPercent = totalCh > 0 ? Math.round((completedCh / totalCh) * 100) : 0;
            
            if (completedCh > 0 || Object.keys(progressState.chapterPositions || {}).length > 0) {
              const imgContainer = card.querySelector('.aspect-video');
              if (imgContainer && !card.querySelector('.card-progress-bar-container')) {
                const progressOverlay = document.createElement('div');
