---
import Layout from '../layouts/Layout.astro';
import { getAllCourses, getYoutubeThumbnail } from '../lib/firebase.js';

const courses = await getAllCourses();

// Define SEO title and description
const title = "Curated Free YouTube Courses Dashboard";
const description = "Explore and filter high-quality curated YouTube courses for AI Engineering, Video Editing, and Coding Skills.";
---

<Layout title={title} description={description}>
  <!-- Navigation Bar -->
  <nav class="sticky top-0 z-50 bg-canvas/95 backdrop-blur border-b border-hairline px-6 py-4 md:px-12 flex justify-between items-center transition-all gap-4">
    <a href="/" class="flex items-center gap-2 group shrink-0">
      <!-- Video Screen Play Icon -->
      <svg class="h-6 w-6 text-primary transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor">
        <path d="M21 3H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h5v2h8v-2h5c1.1 0 1.99-.9 1.99-2L23 5c0-1.1-.9-2-2-2zm0 14H3V5h18v12zm-5-6l-7 4V7l7 4z"/>
      </svg>
      <span class="font-mono text-lg font-bold tracking-widest text-ink group-hover:text-primary transition-colors hidden sm:inline">
        FREEYT<span class="text-primary">COURSES</span>
      </span>
    </a>

    <!-- Center Search Container: YouTube style! -->
    <div id="search-container" class="relative w-full max-w-xs sm:max-w-md md:max-w-lg mx-auto flex items-center">
      <div class="relative w-full">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-mute">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </span>
        <input 
          type="text" 
          id="search-input" 
          placeholder="Search courses, topics, or creators..." 
          class="w-full bg-canvas-soft border border-hairline text-ink rounded-sm pl-10 pr-10 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all placeholder-mute/40"
        />
        <button 
          id="clear-search-btn" 
          type="button" 
          class="absolute inset-y-0 right-0 flex items-center pr-3 text-mute hover:text-ink hidden cursor-pointer bg-transparent border-none focus:outline-none"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Autocomplete Suggestion Dropdown Overlay -->
      <div 
        id="search-suggestions-dropdown" 
        class="absolute left-0 right-0 top-full mt-1.5 bg-canvas border border-hairline rounded-sm shadow-2xl z-50 overflow-hidden divide-y divide-hairline/40 hidden"
      >
        <!-- Suggestions dynamically rendered here -->
      </div>
    </div>

    <!-- Right-aligned items -->
    <div class="flex items-center gap-4 md:gap-6 shrink-0">
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-sm text-body hover:text-ink transition-colors hidden md:inline">
        GitHub
      </a>
      <a href="#about" class="text-sm text-body hover:text-ink transition-colors hidden md:inline">
        About
      </a>
      <a href="/admin/upload" class="text-xs font-mono uppercase border border-hairline hover:border-primary text-body hover:text-primary px-3 py-1.5 rounded-sm transition-all hidden sm:inline">
        Ingestion
      </a>
      <a href="#courses-section" class="text-xs font-mono uppercase bg-primary text-on-primary px-3 py-1.5 rounded-sm hover:bg-primary-soft transition-colors font-semibold">
        Browse
      </a>
    </div>
  </nav>

  <!-- Hero Section -->
  <header class="max-w-6xl mx-auto px-6 pt-16 pb-12 md:pt-24 md:pb-16 text-center">
    <div class="inline-block font-mono text-xs text-primary uppercase tracking-[2.52px] mb-4 bg-primary/10 px-3 py-1.5 rounded-pill border border-primary/20">
      Engineered Learning
    </div>
    <h1 class="text-4xl md:text-6xl font-light text-ink-strong tracking-[-0.65px] leading-tight max-w-3xl mx-auto mb-6">
      Curated YouTube Courses <br class="hidden md:inline" />Dressed as Documentation.
    </h1>
    <p class="text-lg text-body max-w-2xl mx-auto mb-12 font-light leading-relaxed">
      No fluff, no paywalls. High-quality structured learning modules meticulously reviewed and organized by core developer tools.
    </p>

    <!-- Visual Dashboard Grid / Filter Navigation Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-16 text-left">
      <!-- AI Engineering -->
      <button 
        id="filter-card-ai" 
        data-filter-value="AI Engineering" 
        class="filter-card group text-left p-6 bg-canvas border border-hairline rounded-md hover:border-primary/50 transition-all duration-300 relative overflow-hidden focus:outline-none focus:ring-1 focus:ring-primary"
      >
        <div class="flex justify-between items-start mb-4">
          <div class="h-10 w-10 rounded-sm bg-canvas-soft border border-hairline flex items-center justify-center text-primary group-hover:bg-primary/10 transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <span class="font-mono text-xs text-mute group-hover:text-primary transition-colors">MODULE_01</span>
        </div>
        <h3 class="text-lg font-semibold text-ink mb-1 group-hover:text-primary transition-colors">AI Engineering</h3>
        <p class="text-sm text-body line-clamp-2">LangChain, PyTorch, Vector DBs, and agentic workflows.</p>
        <div class="mt-4 pt-4 border-t border-hairline flex items-center gap-1.5 text-xs font-mono text-mute">
          <span>Active courses:</span>
          <span class="text-ink font-semibold">2</span>
        </div>
      </button>

      <!-- Video Editing -->
      <button 
        id="filter-card-video" 
        data-filter-value="Video Editing" 
        class="filter-card group text-left p-6 bg-canvas border border-hairline rounded-md hover:border-primary/50 transition-all duration-300 relative overflow-hidden focus:outline-none focus:ring-1 focus:ring-primary"
      >
        <div class="flex justify-between items-start mb-4">
          <div class="h-10 w-10 rounded-sm bg-canvas-soft border border-hairline flex items-center justify-center text-primary group-hover:bg-primary/10 transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="font-mono text-xs text-mute group-hover:text-primary transition-colors">MODULE_02</span>
        </div>
        <h3 class="text-lg font-semibold text-ink mb-1 group-hover:text-primary transition-colors">Video Editing</h3>
        <p class="text-sm text-body line-clamp-2">DaVinci Resolve, Premiere Pro, motion graphics, and audio mastering.</p>
        <div class="mt-4 pt-4 border-t border-hairline flex items-center gap-1.5 text-xs font-mono text-mute">
          <span>Active courses:</span>
          <span class="text-ink font-semibold">2</span>
        </div>
      </button>

      <!-- Coding Skills -->
      <button 
        id="filter-card-coding" 
        data-filter-value="Coding Skills" 
        class="filter-card group text-left p-6 bg-canvas border border-hairline rounded-md hover:border-primary/50 transition-all duration-300 relative overflow-hidden focus:outline-none focus:ring-1 focus:ring-primary"
      >
        <div class="flex justify-between items-start mb-4">
          <div class="h-10 w-10 rounded-sm bg-canvas-soft border border-hairline flex items-center justify-center text-primary group-hover:bg-primary/10 transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <span class="font-mono text-xs text-mute group-hover:text-primary transition-colors">MODULE_03</span>
        </div>
        <h3 class="text-lg font-semibold text-ink mb-1 group-hover:text-primary transition-colors">Coding Skills</h3>
        <p class="text-sm text-body line-clamp-2">Python design patterns, concurrent programming, Vite, and Tailwind v4.</p>
        <div class="mt-4 pt-4 border-t border-hairline flex items-center gap-1.5 text-xs font-mono text-mute">
          <span>Active courses:</span>
          <span class="text-ink font-semibold">2</span>
        </div>
      </button>
    </div>

    <!-- Dashed Divider -->
    <div class="border-rhythm max-w-5xl mx-auto my-4"></div>
  </header>

  <!-- Courses Dashboard Area -->
  <main id="courses-section" class="max-w-6xl mx-auto px-6 pb-24 scroll-mt-24">
    
    <!-- User Retention (Watch History Engine): Continue Learning Section -->
    <section id="continue-learning-section" class="hidden mb-12 bg-canvas border border-hairline rounded-md p-6">
      <div class="flex items-center gap-2 mb-4">
        <svg class="h-4 w-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h2 class="text-xs font-mono uppercase tracking-[2.52px] text-ink-strong font-semibold">Continue Learning</h2>
      </div>
      <div id="continue-learning-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Dynamically populated via client script -->
      </div>
      <div class="border-rhythm mt-8"></div>
    </section>

    <!-- Filters & Sort Controls Bar -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8 pb-6 border-b border-hairline">
      <!-- Active Filter Pill display -->
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs font-mono uppercase tracking-wider text-mute mr-2">Filter Skill:</span>
        <button id="filter-btn-all" data-filter-value="All" class="filter-pill px-3 py-1 text-xs font-mono uppercase rounded-pill border border-primary bg-primary/15 text-primary transition-all">
          All Courses
        </button>
        <button id="filter-btn-ai" data-filter-value="AI Engineering" class="filter-pill px-3 py-1 text-xs font-mono uppercase rounded-pill border border-hairline hover:border-mute transition-all text-body hover:text-ink">
          AI Engineering
        </button>
        <button id="filter-btn-video" data-filter-value="Video Editing" class="filter-pill px-3 py-1 text-xs font-mono uppercase rounded-pill border border-hairline hover:border-mute transition-all text-body hover:text-ink">
          Video Editing
        </button>
        <button id="filter-btn-coding" data-filter-value="Coding Skills" class="filter-pill px-3 py-1 text-xs font-mono uppercase rounded-pill border border-hairline hover:border-mute transition-all text-body hover:text-ink">
          Coding Skills
        </button>
      </div>

      <!-- Sorting Tabs -->
      <div class="flex items-center gap-1 bg-canvas-soft border border-hairline p-1 rounded-sm">
        <span class="text-xs font-mono uppercase tracking-wider text-mute px-3 hidden lg:inline">Sort by:</span>
        <button 
          id="sort-btn-latest" 
          data-sort-value="latest"
          class="sort-tab px-3 py-1.5 text-xs font-mono uppercase rounded-xs bg-canvas text-primary border border-primary transition-all focus:outline-none"
        >
          Latest
        </button>
        <button 
          id="sort-btn-popular" 
          data-sort-value="popular"
          class="sort-tab px-3 py-1.5 text-xs font-mono uppercase rounded-xs bg-transparent text-body hover:text-ink transition-all focus:outline-none"
        >
          Most Popular
        </button>
        <button 
          id="sort-btn-top-rated" 
          data-sort-value="top-rated"
          class="sort-tab px-3 py-1.5 text-xs font-mono uppercase rounded-xs bg-transparent text-body hover:text-ink transition-all focus:outline-none"
        >
          Top Rated
        </button>
      </div>
    </div>

    <!-- Course Cards Grid -->
    <div id="course-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {courses.map((course) => (
        <article 
          class="course-card group bg-canvas-soft border border-hairline rounded-md flex flex-col justify-between hover:border-primary/45 transition-all duration-300 relative overflow-hidden h-full cursor-pointer"
          data-id={course.id}
          data-category={course.category}
          data-views={course.views}
          data-votes={course.votes}
          data-rating={course.rating}
          data-date={course.publishDate}
          data-creator={course.creatorName}
          data-slug={course.slug}
        >
          <!-- Prominent Thumbnail & Promo Badge -->
          <div class="relative aspect-video w-full overflow-hidden border-b border-hairline bg-canvas">
            <img 
              src={getYoutubeThumbnail(course.sampleVideoId)} 
              alt={`${course.title} thumbnail`} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <span class={`absolute top-3 right-3 text-[10px] font-mono uppercase tracking-wider px-2.5 py-0.5 rounded-sm font-semibold shadow-md ${course.type === 'paid' ? 'bg-amber-400 text-on-primary border border-amber-500/20' : 'bg-primary text-on-primary border border-primary-soft/20'}`}>
              {course.type}
            </span>
          </div>

          <!-- Bottom Card Content (padded) -->
          <div class="p-6 flex flex-col justify-between flex-grow">
            <div>
              <!-- Header Category / Duration Tag -->
              <div class="flex justify-between items-center mb-3">
                <span class="text-[10px] font-mono uppercase bg-canvas border border-hairline px-2.5 py-0.5 rounded-pill text-body">
                  {course.category}
                </span>
                <span class="text-xs font-mono text-mute">{course.duration}</span>
              </div>

              <!-- Title -->
              <h2 class="text-lg font-semibold text-ink-strong mb-2.5 group-hover:text-primary transition-colors line-clamp-2 leading-snug">
                <a href={`/courses/${course.slug}`} class="focus:outline-none after:absolute after:inset-0">
                  {course.title}
                </a>
              </h2>

              <!-- Creator Row -->
              <div class="flex items-center gap-2 mb-4">
                <img 
                  src={course.creatorLogo} 
                  alt={course.creatorName} 
                  class="h-6 w-6 rounded-full object-cover border border-hairline shrink-0"
                />
                <span class="text-xs font-mono text-mute">{course.creatorName}</span>
              </div>

              <!-- Excerpt -->
              <p class="text-xs text-body mb-5 line-clamp-2 leading-relaxed">
                {course.description}
              </p>
            </div>

            <div>
              <!-- Required tools list styled as inline code chips -->
              <div class="flex flex-wrap gap-1.5 mb-5">
                {course.tools.slice(0, 3).map((tool) => (
                  <span class="text-[9px] font-mono bg-canvas text-canvas-text-soft border border-hairline px-2 py-0.5 rounded-sm">
                    {tool}
                  </span>
                ))}
                {course.tools.length > 3 && (
                  <span class="text-[9px] font-mono bg-canvas text-mute border border-hairline px-2 py-0.5 rounded-sm">
                    +{course.tools.length - 3} more
                  </span>
                )}
              </div>

              <!-- Metrics Footer inside Card -->
              <div class="pt-3.5 border-t border-hairline flex justify-between items-center text-[11px] font-mono text-mute">
                <!-- Rating & Votes -->
                <div class="flex items-center gap-1">
                  <svg class="h-3.5 w-3.5 text-primary fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                  <span class="text-ink font-semibold">{course.rating.toFixed(1)}</span>
                  <span class="text-[10px]">({course.votes})</span>
                </div>
                
                <!-- Views -->
                <div class="flex items-center gap-1">
                  <span class="text-ink font-semibold">{course.views.toLocaleString()}</span>
                  <span class="text-[10px]">views</span>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty state card when filters match zero courses -->
    <div id="empty-state" class="hidden text-center p-12 bg-canvas-soft border border-hairline border-dashed rounded-md my-12 max-w-xl mx-auto">
      <svg class="mx-auto h-12 w-12 text-mute mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="text-lg font-semibold text-ink mb-1 font-mono uppercase tracking-wider">No Courses Found</h3>
      <p class="text-sm text-body">No curated courses match the selected search parameters or skill categories.</p>
    </div>

    <!-- Embedded courses JSON data store block -->
    <div id="courses-data" data-courses={JSON.stringify(courses)} class="hidden"></div>
  </main>

  <!-- About Section -->
  <section id="about" class="bg-canvas-soft border-t border-hairline py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="font-mono text-xs text-primary uppercase tracking-[2.52px] mb-4">
        EDITORIAL STANDARDS
      </div>
      <h2 class="text-2xl md:text-3xl font-light text-ink-strong mb-6 tracking-tight">
        Why FreeYTCourses Exists
      </h2>
      <div class="space-y-4 text-body text-sm md:text-base leading-relaxed">
        <p>
          The internet is saturated with excellent educational content. YouTube houses thousands of hours of high-quality courses uploaded by experts. However, these courses are often hard to find, unindexed, or mixed with low-effort videos.
        </p>
        <p>
          We curate, structure, and verify tutorials by breaking them down into modules, listing required toolsets, and reviewing the core syllabus. Every single page in this hub contains a minimum 200-word detailed critique to guarantee compliance with premium search parameters, avoiding generic index placeholders.
        </p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-canvas border-t border-hairline py-12 px-6 text-center text-xs font-mono text-mute">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
      <div>
        &copy; {new Date().getFullYear()} FreeYTCourses. Curated under the Voltagent aesthetic guidelines.
      </div>
      <div class="flex gap-6">
        <a href="#" class="hover:text-ink transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-ink transition-colors">Terms of Service</a>
        <a href="https://google.com/adsense" class="hover:text-ink transition-colors">AdSense Notice</a>
      </div>
    </div>
  </footer>

  <!-- Client-Side Filter, Search, Sort & History Script -->
  <script>
    // Elements
    const filterCards = document.querySelectorAll('.filter-card');
    const filterPills = document.querySelectorAll('.filter-pill');
    const sortTabs = document.querySelectorAll('.sort-tab');
    const courseGrid = document.getElementById('course-grid');
    const emptyState = document.getElementById('empty-state');
    
    // Youtube Top Search Elements
    const searchContainer = document.getElementById('search-container');
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const clearSearchBtn = document.getElementById('clear-search-btn');
    const dropdown = document.getElementById('search-suggestions-dropdown');
    
    let activeFilter = 'All';
    let activeSort = 'latest';
    const HISTORY_KEY = 'freeyt_watch_history';

    // Retrieve courses from data block
    const coursesDataEl = document.getElementById('courses-data');
    const allCourses = JSON.parse(coursesDataEl?.getAttribute('data-courses') || '[]');

    // Event listeners for visual filter cards (Hero grid)
    filterCards.forEach((card) => {
      card.addEventListener('click', () => {
        const val = card.getAttribute('data-filter-value');
        if (val) {
          setFilter(val);
          // Scroll down to the course grid smoothly
          document.getElementById('courses-section')?.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });

    // Event listeners for category pills
    filterPills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const val = pill.getAttribute('data-filter-value');
        if (val) setFilter(val);
      });
    });

    // Event listeners for sorting tabs
    sortTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const val = tab.getAttribute('data-sort-value');
        if (val) setSort(val);
      });
    });

    // YouTube Autocomplete & Clear Button Interactivity
    searchInput?.addEventListener('input', () => {
      const q = searchInput.value;
      if (q.trim()) {
        clearSearchBtn?.classList.remove('hidden');
        renderSuggestions(q);
      } else {
        clearSearchBtn?.classList.add('hidden');
        if (dropdown) dropdown.classList.add('hidden');
      }
      applyFiltersAndSort();
    });

    searchInput?.addEventListener('focus', () => {
      const q = searchInput.value;
      if (q.trim() && dropdown) {
        renderSuggestions(q);
      }
    });

    // Dismiss search dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (searchContainer && !searchContainer.contains(e.target as Node)) {
        dropdown?.classList.add('hidden');
      }
    });

    clearSearchBtn?.addEventListener('click', () => {
      searchInput.value = '';
      clearSearchBtn.classList.add('hidden');
      if (dropdown) dropdown.classList.add('hidden');
      applyFiltersAndSort();
      searchInput.focus();
    });

    // Levenshtein distance calculation for powerful fuzzy search
    function getLevenshteinDistance(a: string, b: string): number {
      const matrix: number[][] = [];
      for (let i = 0; i <= b.length; i++) matrix[i] = [i];
      for (let j = 0; j <= a.length; j++) matrix[0][j] = j;
      for (let i = 1; i <= b.length; i++) {
        for (let j = 1; j <= a.length; j++) {
          if (b.charAt(i - 1) === a.charAt(j - 1)) {
            matrix[i][j] = matrix[i - 1][j - 1];
          } else {
            matrix[i][j] = Math.min(
              matrix[i - 1][j - 1] + 1, // substitution
              matrix[i][j - 1] + 1,     // insertion
              matrix[i - 1][j] + 1      // deletion
            );
          }
        }
      }
      return matrix[b.length][a.length];
    }

    // Powerful Case-Insensitive, Tokenized, and Levenshtein Fuzzy Search Match
    function searchMatch(course: any, query: string): boolean {
      const q = query.toLowerCase().trim();
      if (!q) return true;

      const title = course.title.toLowerCase();
      const creator = course.creatorName.toLowerCase();
      const category = course.category.toLowerCase();
      const description = course.description.toLowerCase();
      const tools = course.tools.map((t: string) => t.toLowerCase()).join(' ');

      // 1. Exact case-insensitive substring matches
      if (title.includes(q) || creator.includes(q) || category.includes(q) || description.includes(q) || tools.includes(q)) {
        return true;
      }

      // 2. Tokenized multi-word search matching
      const words = q.split(/\s+/).filter(Boolean);
      if (words.length > 1) {
        const combinedText = `${title} ${creator} ${category} ${tools}`;
        if (words.every(w => combinedText.includes(w))) {
          return true;
        }
      }

      // 3. Levenshtein fuzzy distance matching on word tokens
      if (q.length >= 3) {
        const courseTokens = [...title.split(/[\s,.-]+/), ...creator.split(/[\s,.-]+/)].filter(t => t.length >= 3);
        for (const token of courseTokens) {
          const dist = getLevenshteinDistance(q, token);
          // Distance threshold: <= 1 for short queries, <= 2 for queries 4+ chars
          if (dist <= 1 || (q.length >= 4 && dist <= 2)) {
            return true;
          }
        }
      }

      return false;
    }

    // Highlight query text matches inside the suggestions dropdown
    function highlightText(text: string, query: string): string {
      if (!query.trim()) return text;
      const escapedQuery = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const regex = new RegExp(`(${escapedQuery})`, 'gi');
      return text.replace(regex, '<span class="text-primary font-bold">$1</span>');
    }

    function renderSuggestions(query: string) {
      if (!dropdown) return;
      
      const matches = allCourses.filter((c: any) => searchMatch(c, query));
      
      if (matches.length === 0) {
        dropdown.innerHTML = `
          <div class="p-3 text-xs text-mute font-mono">
            No suggestions found
          </div>
        `;
        dropdown.classList.remove('hidden');
        return;
      }

      dropdown.innerHTML = '';
      
      // Render suggestion items (limit to 5 like YouTube)
      matches.slice(0, 5).forEach((course: any) => {
        const videoId = course.sampleVideoId;
        const thumbnailUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
        
        const item = document.createElement('a');
        item.href = `/courses/${course.slug}`;
        item.className = "flex items-center gap-3 p-3.5 hover:bg-canvas-soft transition-colors text-left group cursor-pointer focus:outline-none focus:bg-canvas-soft";
        
        item.innerHTML = `
          <img src="${thumbnailUrl}" class="h-9 w-14 object-cover rounded-sm border border-hairline shrink-0" />
          <div class="overflow-hidden">
            <h4 class="text-xs font-semibold text-ink-strong group-hover:text-primary transition-colors line-clamp-1 leading-snug">
              ${highlightText(course.title, query)}
            </h4>
            <span class="text-[10px] font-mono text-mute">
              by ${highlightText(course.creatorName, query)}
            </span>
          </div>
        `;

        item.addEventListener('click', () => {
          addToHistory(course.slug);
        });

        dropdown.appendChild(item);
      });

      // Suggestion dropdown header / footer actions
      const footerAction = document.createElement('div');
      footerAction.className = "p-2 bg-canvas-soft/40 text-[10px] font-mono text-mute text-right border-t border-hairline/25";
      footerAction.textContent = "Press Enter to filter results below";
      dropdown.appendChild(footerAction);

      dropdown.classList.remove('hidden');
    }

    // Trigger full filter when pressing enter in search
    searchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        applyFiltersAndSort();
        dropdown?.classList.add('hidden');
        searchInput.blur();
      }
    });

    function setFilter(category: string) {
      activeFilter = category;
      
      // Update UI visual state of pills
      filterPills.forEach((pill) => {
        const pillVal = pill.getAttribute('data-filter-value');
        if (pillVal === category) {
          pill.className = "filter-pill px-3 py-1 text-xs font-mono uppercase rounded-pill border border-primary bg-primary/15 text-primary transition-all";
        } else {
          pill.className = "filter-pill px-3 py-1 text-xs font-mono uppercase rounded-pill border border-hairline hover:border-mute transition-all text-body hover:text-ink";
        }
      });

      // Update UI visual state of hero grid cards
      filterCards.forEach((card) => {
        const cardVal = card.getAttribute('data-filter-value');
        if (cardVal === category) {
          card.classList.add('border-primary');
          card.classList.remove('border-hairline');
        } else {
          card.classList.remove('border-primary');
          card.classList.add('border-hairline');
        }
      });

      applyFiltersAndSort();
    }

    function setSort(sortType: string) {
      activeSort = sortType;

      // Update UI of sort tabs
      sortTabs.forEach((tab) => {
        const tabVal = tab.getAttribute('data-sort-value');
        if (tabVal === sortType) {
          tab.className = "sort-tab px-3 py-1.5 text-xs font-mono uppercase rounded-xs bg-canvas text-primary border border-primary transition-all focus:outline-none";
        } else {
          tab.className = "sort-tab px-3 py-1.5 text-xs font-mono uppercase rounded-xs bg-transparent text-body hover:text-ink transition-all focus:outline-none";
        }
      });

      applyFiltersAndSort();
    }

    function applyFiltersAndSort() {
      if (!courseGrid) return;
      const cards = Array.from(courseGrid.getElementsByClassName('course-card')) as HTMLElement[];
      const searchQuery = searchInput?.value || '';
      let visibleCount = 0;

      // 1. Filter by category & search query (using upgraded searchMatch logic)
      cards.forEach((card) => {
        const cat = card.getAttribute('data-category');
        const slug = card.getAttribute('data-slug');
        const course = allCourses.find((c: any) => c.slug === slug);

        const matchesCategory = activeFilter === 'All' || cat === activeFilter;
        const matchesSearch = course ? searchMatch(course, searchQuery) : true;

        if (matchesCategory && matchesSearch) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      // Show/hide empty state
      if (visibleCount === 0) {
        emptyState?.classList.remove('hidden');
        courseGrid.classList.add('hidden');
      } else {
        emptyState?.classList.add('hidden');
        courseGrid.classList.remove('hidden');
      }

      // 2. Sort visible cards
      cards.sort((a, b) => {
        if (activeSort === 'latest') {
          const dateA = new Date(a.getAttribute('data-date') || '');
          const dateB = new Date(b.getAttribute('data-date') || '');
          return dateB.getTime() - dateA.getTime();
        } else if (activeSort === 'popular') {
          const viewsA = Number(a.getAttribute('data-views') || 0);
          const viewsB = Number(b.getAttribute('data-views') || 0);
          return viewsB - viewsA;
        } else if (activeSort === 'top-rated') {
          // Weighted average calculation using rating and logarithmic vote count
          const ratingA = Number(a.getAttribute('data-rating') || 0);
          const votesA = Number(a.getAttribute('data-votes') || 0);
          const ratingB = Number(b.getAttribute('data-rating') || 0);
          const votesB = Number(b.getAttribute('data-votes') || 0);
          
          const scoreA = ratingA * Math.log10(votesA + 1);
          const scoreB = ratingB * Math.log10(votesB + 1);
          
          return scoreB - scoreA;
        }
        return 0;
      });

      // Re-append sorted nodes to the grid DOM container
      cards.forEach((card) => {
        courseGrid.appendChild(card);
      });
    }

    // User Retention: LocalStorage Watch History Engine
    function addToHistory(slug: string) {
      let history: string[] = [];
      try {
        const raw = localStorage.getItem(HISTORY_KEY);
        if (raw) {
          history = JSON.parse(raw);
        }
      } catch (e) {
        console.error(e);
      }

      if (!Array.isArray(history)) {
        history = [];
      }

      // Prepend to history & remove duplicates
      history = history.filter(item => item !== slug);
      history.unshift(slug);

      // Keep only top 4 items
      if (history.length > 4) {
        history = history.slice(0, 4);
      }

      localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
    }

    function renderContinueLearning() {
      const container = document.getElementById('continue-learning-section');
      const grid = document.getElementById('continue-learning-grid');
      if (!container || !grid) return;

      let history: string[] = [];
      try {
        const raw = localStorage.getItem(HISTORY_KEY);
        if (raw) {
          history = JSON.parse(raw);
        }
      } catch (e) {
        console.error(e);
      }

      if (!Array.isArray(history) || history.length === 0) {
        container.classList.add('hidden');
        return;
      }

      grid.innerHTML = '';
      let count = 0;

      history.forEach((slug) => {
        const course = allCourses.find((c: any) => c.slug === slug);
        if (course) {
          count++;
          const thumbnailUrl = `https://img.youtube.com/vi/${course.sampleVideoId}/maxresdefault.jpg`;
          
          const cardHtml = `
            <a href="/courses/${course.slug}" class="group bg-canvas-soft border border-hairline rounded-md p-4 flex gap-4 hover:border-primary/45 transition-all duration-300 relative overflow-hidden">
              <img src="${thumbnailUrl}" class="h-16 w-24 object-cover rounded-sm shrink-0 border border-hairline" alt="${course.title} thumbnail" />
              <div class="flex flex-col justify-between overflow-hidden flex-grow">
                <div>
                  <span class="text-[9px] font-mono uppercase text-primary tracking-wider">${course.category}</span>
                  <h3 class="text-xs font-semibold text-ink-strong group-hover:text-primary transition-colors line-clamp-1 mt-0.5">${course.title}</h3>
                </div>
                <div class="flex items-center gap-1.5 mt-2">
                  <img src="${course.creatorLogo}" class="h-4 w-4 rounded-full border border-hairline object-cover" alt="${course.creatorName}" />
                  <span class="text-[10px] font-mono text-mute line-clamp-1">${course.creatorName}</span>
                </div>
              </div>
            </a>
          `;
          grid.insertAdjacentHTML('beforeend', cardHtml);
        }
      });

      if (count > 0) {
        container.classList.remove('hidden');
      } else {
        container.classList.add('hidden');
      }
    }

    // Attach click listeners to cards to record visits
    document.querySelectorAll('.course-card').forEach((card) => {
      card.addEventListener('click', () => {
        const slug = card.getAttribute('data-slug');
        if (slug) {
          addToHistory(slug);
        }
      });
    });

    // Run on page load
    renderContinueLearning();
    applyFiltersAndSort();
  </script>
</Layout>
