---
import Layout from '../../layouts/Layout.astro';
import { getAllCourses, getCreatorSlug, getYoutubeThumbnail } from '../../lib/firebase.js';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const allCourses = await getAllCourses();
const creatorCourses = allCourses.filter(c => getCreatorSlug(c.creatorName) === slug);

if (creatorCourses.length === 0) {
  return Astro.redirect('/404');
}

// Grab creator details
const creatorName = creatorCourses[0].creatorName;
const creatorLogo = creatorCourses[0].creatorLogo;

// Derive subscriber count & handles
const nameHash = creatorName.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0);
const subscribersCount = creatorCourses[0].creatorSubscribers || `${((nameHash % 900) + 10).toFixed(1)}K subscribers`;
const videoCount = `${creatorCourses.length} course${creatorCourses.length > 1 ? 's' : ''}`;
const handle = `@${slug.replace(/-/g, '')}`;

// Custom creator descriptions based on curated profiles
let bio = "Curated content publisher sharing structured tutorials, hands-on programming guides, and technical walkthroughs.";
if (creatorName.includes("Thorne")) {
  bio = "Academic researcher and software engineer specializing in autonomous agent systems, cognitive architectures, and LLM orchestration tools.";
} else if (creatorName.includes("Sterling")) {
  bio = "Post-production engineer and film editor. Publishing detailed post-production workflows, node-based color grading, and audio mastering suites.";
} else if (creatorName.includes("Rostova")) {
  bio = "Software architect focusing on clean code constructs, concurrent computing paradigms, performance profiling, and structural design patterns.";
} else if (creatorName.includes("Kade")) {
  bio = "Frontend developer pushing the boundaries of web UI engineering, Vite compile optimization, and Tailwind CSS v4 CSS-first designs.";
} else if (creatorName.includes("Lindqvist")) {
  bio = "Motion designer and kinetic typographer. Combining Premiere Pro editing pipelines with After Effects keyframe animation.";
} else if (creatorName.includes("Vance")) {
  bio = "Computer science professor specializing in deep learning, tensor calculus optimizations, GPU CUDA acceleration, and PyTorch training.";
}

const title = `${creatorName} - Creator Profile`;
const description = `Explore all curated structured courses, syllabus breakdowns, and video tutorials created by ${creatorName}.`;
---

<Layout title={title} description={description} activePage="subscriptions">


  <main class="max-w-6xl mx-auto px-6 py-8 md:py-12">
    <!-- Channel Header Metadata Area -->
    <header class="flex flex-col md:flex-row gap-6 md:gap-8 items-start md:items-center pb-8 border-b border-hairline">
      <!-- Creator Big Avatar Logo -->
      <img 
        src={creatorLogo} 
        alt={creatorName} 
        class="h-24 w-24 md:h-32 md:w-32 rounded-full object-cover border border-hairline shrink-0 shadow-xl"
      />
      
      <div class="space-y-3 flex-grow max-w-3xl">
        <h1 class="text-3xl md:text-4xl font-light text-ink-strong tracking-tight leading-none">
          {creatorName}
        </h1>
        
        <!-- Subscriber & Course details -->
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs font-mono text-mute">
          <span class="text-ink font-semibold">{handle}</span>
          <span class="text-hairline">•</span>
          <span>{subscribersCount}</span>
          <span class="text-hairline">•</span>
          <span class="text-primary font-semibold">{videoCount}</span>
        </div>
        
        <p class="text-sm text-body leading-relaxed font-light">
          {bio}
        </p>
        
        <div class="flex flex-wrap items-center gap-3 pt-2">
          <button id="subscribe-btn" class="px-5 py-1.5 font-mono text-xs uppercase rounded-sm transition-all flex items-center gap-1.5 select-none cursor-pointer">
            <span id="subscribe-text">Subscribe</span>
          </button>
        </div>
      </div>
    </header>

    <!-- Channel Tabs Navigation & Custom Search Sub-Bar -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center border-b border-hairline mb-8 gap-4">
      <div class="flex items-center gap-6 font-mono text-xs uppercase tracking-wider">
        <span class="py-4 border-b-2 border-primary text-primary font-bold">
          Courses
        </span>
      </div>

      <!-- Channel Search and Sort Row -->
      <div class="flex flex-wrap items-center gap-3 py-2.5 w-full md:w-auto">
        <!-- Inner Channel Search -->
        <div class="relative w-full sm:w-48">
          <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="channel-search-input"
            placeholder="Search channel courses..."
            class="w-full bg-canvas-soft border border-hairline text-ink rounded-sm py-1.5 pl-8 pr-3 text-xs focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/20 transition-all font-mono"
          />
        </div>

        <!-- Sorting Pills -->
        <div class="flex items-center gap-1 bg-canvas-soft border border-hairline p-1 rounded-sm text-[10px] font-mono uppercase">
          <button id="sort-latest" class="sort-pill px-2.5 py-1 text-primary bg-canvas border border-hairline transition-all cursor-pointer">
            Latest
          </button>
          <button id="sort-popular" class="sort-pill px-2.5 py-1 text-body hover:text-ink hover:bg-canvas/30 transition-all cursor-pointer">
            Popular
          </button>
          <button id="sort-rating" class="sort-pill px-2.5 py-1 text-body hover:text-ink hover:bg-canvas/30 transition-all cursor-pointer">
            Top Rated
          </button>
        </div>
      </div>
    </div>

    <!-- Courses Grid List -->
    <div id="channel-courses-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {creatorCourses.map((course) => (
        <article 
          class="course-card group bg-canvas-soft border border-hairline rounded-md flex flex-col justify-between hover:border-primary/45 transition-all duration-300 relative overflow-hidden h-full cursor-pointer"
          data-slug={course.slug}
          data-date={course.publishDate}
          data-views={course.views}
          data-rating={course.rating}
          data-votes={course.votes}
          data-title={course.title}
        >
          <!-- Video Thumbnail image -->
          <div class="relative aspect-video w-full overflow-hidden border-b border-hairline bg-canvas">
            <img 
              src={getYoutubeThumbnail(course.sampleVideoId)} 
              alt={`${course.title} thumbnail`} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <!-- Always-Visible Watch Later Button -->
            <button 
              type="button" 
              class="watch-later-toggle-btn absolute top-2.5 left-2.5 z-30 bg-canvas/95 hover:bg-primary hover:text-on-primary text-ink px-2.5 py-1 rounded-sm transition-all shadow-md focus:outline-none cursor-pointer border border-hairline hover:border-primary flex items-center gap-1.5 text-[11px] font-mono"
              data-slug={course.slug}
              title="Save to Watch Later"
            >
              <svg class="h-3.5 w-3.5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="wl-label pointer-events-none">Watch later</span>
            </button>
            <span class={`absolute top-3 right-3 text-[10px] font-mono uppercase tracking-wider px-2.5 py-0.5 rounded-sm font-semibold shadow-md ${course.type === 'paid' ? 'bg-amber-400 text-on-primary border border-amber-500/20' : 'bg-primary text-on-primary border border-primary-soft/20'}`}>
              {course.type}
            </span>
            <!-- Modules Count Overlay Badge -->
            <div class="absolute bottom-2.5 right-2.5 z-20 bg-canvas/90 backdrop-blur-sm text-ink-strong border border-hairline px-2 py-0.5 rounded-sm text-[10px] font-mono flex items-center gap-1.5 shadow-md">
              <svg class="h-3 w-3 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
              <span>{course.chapters?.length || 0} Modules</span>
            </div>
          </div>

          <!-- Card text body details -->
          <div class="p-5 flex flex-grow flex-col justify-between">
            <div>
              <div class="flex justify-between items-center mb-3">
                <span class="text-[9px] font-mono uppercase bg-canvas border border-hairline px-2.5 py-0.5 rounded-pill text-body">
                  {course.category}
                </span>
                <span class="text-xs font-mono text-mute">{course.duration}</span>
              </div>

              <h2 class="text-base font-semibold text-ink-strong mb-2 group-hover:text-primary transition-colors line-clamp-2 leading-snug">
                <a href={`/courses/${course.slug}`} class="focus:outline-none after:absolute after:inset-0">
                  {course.title}
                </a>
              </h2>

              <p class="text-xs text-body line-clamp-2 leading-relaxed mb-4 font-light">
                {course.description}
              </p>
            </div>

            <div>
              <!-- Metrics inside card -->
              <div class="pt-3 border-t border-hairline flex justify-between items-center text-[10px] font-mono text-mute">
                <div class="flex items-center gap-1">
                  <svg class="h-3.5 w-3.5 text-primary fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                  <span class="text-ink font-semibold">{course.rating.toFixed(1)}</span>
                </div>
                
                <div class="flex items-center gap-1">
                  <span class="text-ink font-semibold">{course.views.toLocaleString()}</span>
                  <span>views</span>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty search matches card -->
    <div id="channel-empty-state" class="hidden text-center p-12 bg-canvas border border-hairline border-dashed rounded-md my-12 max-w-xl mx-auto">
      <svg class="mx-auto h-12 w-12 text-mute mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="text-lg font-semibold text-ink mb-1 font-mono uppercase tracking-wider">No Courses Found</h3>
      <p class="text-sm text-body">No courses match the searched term within this channel.</p>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-canvas border-t border-hairline py-12 px-6 text-center text-xs font-mono text-mute mt-24">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
      <div>
        &copy; {new Date().getFullYear()} FreeYTCourses. Curated creator directory.
      </div>
      <div class="flex gap-6">
        <a href="/" class="hover:text-ink transition-colors">Directory Dashboard</a>
        <a href="#" class="hover:text-ink transition-colors">Submit Curriculum</a>
      </div>
    </div>
  </footer>

  <!-- Client-Side Search, Sort & Progress Script -->
  <script is:inline define:vars={{ creatorSlug: slug }}>
    // Variables
    const searchInput = document.getElementById('channel-search-input');
    const grid = document.getElementById('channel-courses-grid');
    const emptyState = document.getElementById('channel-empty-state');
    const sortPills = document.querySelectorAll('.sort-pill');
    
    let activeSort = 'latest';
    
    // Subscription Logic
    const SUBS_KEY = 'freeyt_subscribed_creators';
    const subBtn = document.getElementById('subscribe-btn');
    
    function getSubscriptions() {
      try {
        const raw = localStorage.getItem(SUBS_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch (e) {
        return [];
      }
    }
    
    function saveSubscriptions(subs) {
      localStorage.setItem(SUBS_KEY, JSON.stringify(subs));
    }
    
    function isSubscribed() {
      const subs = getSubscriptions();
      return subs.includes(creatorSlug);
    }
    
    function updateSubscribeButton() {
      if (!subBtn) return;
      if (isSubscribed()) {
        subBtn.className = "px-5 py-1.5 bg-canvas-soft border border-hairline text-ink-strong font-mono text-xs uppercase rounded-sm hover:border-primary transition-all flex items-center gap-1.5 select-none cursor-pointer";
        subBtn.innerHTML = `
          <svg class="h-3.5 w-3.5 text-primary" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" />
          </svg>
          <span>Subscribed</span>
        `;
      } else {
        subBtn.className = "px-5 py-1.5 bg-primary border border-primary text-on-primary font-mono text-xs uppercase rounded-sm hover:bg-primary-soft transition-all flex items-center gap-1.5 select-none cursor-pointer";
        subBtn.innerHTML = `
          <span>Subscribe</span>
        `;
      }
    }
    
    subBtn?.addEventListener('click', () => {
      let subs = getSubscriptions();
      if (subs.includes(creatorSlug)) {
        subs = subs.filter(s => s !== creatorSlug);
      } else {
        subs.push(creatorSlug);
      }
      saveSubscriptions(subs);
      updateSubscribeButton();
      window.dispatchEvent(new Event('subscriptionsChanged'));
    });
    
    // Initial call
    updateSubscribeButton();
    
    function applySearchAndSort() {
      if (!grid) return;
      const query = searchInput ? searchInput.value.toLowerCase().trim() : '';
      const cards = Array.from(grid.querySelectorAll('.course-card'));
      
      let visibleCount = 0;
      
      cards.forEach((card) => {
        const title = card.getAttribute('data-title')?.toLowerCase() || '';
        const matches = query === '' || title.includes(query);
        
        if (matches) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });
      
      if (visibleCount === 0) {
        emptyState?.classList.remove('hidden');
        grid.classList.add('hidden');
      } else {
        emptyState?.classList.add('hidden');
        grid.classList.remove('hidden');
      }
      
      // Sort matching rows
      cards.sort((a, b) => {
        if (activeSort === 'latest') {
          const dateA = new Date(a.getAttribute('data-date') || '');
          const dateB = new Date(b.getAttribute('data-date') || '');
          return dateB.getTime() - dateA.getTime();
        } else if (activeSort === 'popular') {
          const viewsA = Number(a.getAttribute('data-views') || 0);
          const viewsB = Number(b.getAttribute('data-views') || 0);
          return viewsB - viewsA;
        } else if (activeSort === 'rating') {
          const ratingA = Number(a.getAttribute('data-rating') || 0);
          const votesA = Number(a.getAttribute('data-votes') || 0);
          const ratingB = Number(b.getAttribute('data-rating') || 0);
          const votesB = Number(b.getAttribute('data-votes') || 0);
          const scoreA = ratingA * Math.log10(votesA + 1);
          const scoreB = ratingB * Math.log10(votesB + 1);
          return scoreB - scoreA;
        }
        return 0;
      });
      
      cards.forEach((card) => {
        grid.appendChild(card);
      });
    }

    // Input listener
    searchInput?.addEventListener('input', applySearchAndSort);

    // Sort listener
    sortPills.forEach((pill) => {
      pill.addEventListener('click', () => {
        sortPills.forEach(p => {
          p.classList.remove('text-primary', 'bg-canvas', 'border');
          p.classList.add('text-body', 'hover:text-ink', 'hover:bg-canvas/30');
        });
        
        pill.classList.remove('text-body', 'hover:text-ink', 'hover:bg-canvas/30');
        pill.classList.add('text-primary', 'bg-canvas', 'border');
        
        const id = pill.id;
        if (id === 'sort-latest') activeSort = 'latest';
        else if (id === 'sort-popular') activeSort = 'popular';
        else if (id === 'sort-rating') activeSort = 'rating';
        
        applySearchAndSort();
      });
    });

    // Render local progress on cards
    function renderProgressOnCards() {
      document.querySelectorAll('.course-card').forEach((card) => {
        const slug = card.getAttribute('data-slug');
        if (!slug) return;
        
        const progressKey = `freeyt_progress_${slug}`;
        try {
          const rawProgress = localStorage.getItem(progressKey);
          if (rawProgress) {
            const progressState = JSON.parse(rawProgress);
            const completedCh = Array.isArray(progressState.completedChapters) ? progressState.completedChapters.length : 0;
            const totalCh = 5; // default estimation
            const progressPercent = Math.round((completedCh / totalCh) * 100);
            
            if (completedCh > 0 || Object.keys(progressState.chapterPositions || {}).length > 0) {
              const imgContainer = card.querySelector('.aspect-video');
              if (imgContainer) {
                const progressOverlay = document.createElement('div');
                progressOverlay.className = 'absolute bottom-0 left-0 right-0 h-1.5 bg-canvas border-t border-hairline overflow-hidden z-20';
                progressOverlay.innerHTML = `<div class="h-full bg-primary" style="width: ${progressPercent}%"></div>`;
                imgContainer.appendChild(progressOverlay);
                
                const durationEl = card.querySelector('.text-xs.font-mono.text-mute');
                if (durationEl) {
                  durationEl.innerHTML = `<span class="text-primary font-semibold">${progressPercent}% done</span> <span class="mx-1 text-hairline">|</span> ${durationEl.textContent}`;
                }
              }
            }
          }
        } catch (e) {
          console.error(e);
        }
      });
    }

    // Toast Notification Helper
    function showToast(message, actionText = '', actionUrl = '') {
      let container = document.getElementById('toast-container');
      if (!container) {
        container = document.createElement('div');
        container.id = 'toast-container';
        container.className = 'fixed bottom-6 left-6 z-50 flex flex-col gap-2 pointer-events-none';
        document.body.appendChild(container);
      }

      const toast = document.createElement('div');
      toast.className = 'pointer-events-auto bg-canvas-soft border border-primary/50 text-ink px-4 py-3 rounded-md shadow-2xl flex items-center gap-4 text-xs font-mono transition-all duration-300';
      toast.innerHTML = `
        <div class="flex items-center gap-2">
          <svg class="h-4 w-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>${message}</span>
        </div>
        ${actionText && actionUrl ? `<a href="${actionUrl}" class="text-primary font-bold hover:underline shrink-0">${actionText} &rarr;</a>` : ''}
      `;

      container.appendChild(toast);

      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateY(10px)';
        setTimeout(() => toast.remove(), 300);
      }, 3500);
    }

    function updateWatchLaterButtons() {
      let wl = [];
      try {
        const raw = localStorage.getItem('freeyt_watch_later');
        wl = raw ? JSON.parse(raw) : [];
      } catch (e) {
        wl = [];
      }

      document.querySelectorAll('.watch-later-toggle-btn').forEach(btn => {
        const slug = btn.getAttribute('data-slug');
        const label = btn.querySelector('.wl-label');
        if (slug && Array.isArray(wl) && wl.includes(slug)) {
          btn.className = "watch-later-toggle-btn absolute top-2.5 left-2.5 z-30 bg-primary text-on-primary font-bold px-2.5 py-1 rounded-sm transition-all shadow-md focus:outline-none cursor-pointer border border-primary flex items-center gap-1.5 text-[11px] font-mono";
          if (label) label.textContent = "Saved";
          btn.setAttribute('title', 'Saved to Watch Later (Click to remove)');
        } else {
          btn.className = "watch-later-toggle-btn absolute top-2.5 left-2.5 z-30 bg-canvas/95 hover:bg-primary hover:text-on-primary text-ink px-2.5 py-1 rounded-sm transition-all shadow-md focus:outline-none cursor-pointer border border-hairline hover:border-primary flex items-center gap-1.5 text-[11px] font-mono";
          if (label) label.textContent = "Watch later";
          btn.setAttribute('title', 'Save to Watch Later');
        }
      });
    }

    document.querySelectorAll('.watch-later-toggle-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const slug = btn.getAttribute('data-slug');
        if (!slug) return;

        let wl = [];
        try {
          const raw = localStorage.getItem('freeyt_watch_later');
          wl = raw ? JSON.parse(raw) : [];
        } catch (e) {
          wl = [];
        }

        const isSaved = wl.includes(slug);
        if (isSaved) {
          wl = wl.filter(s => s !== slug);
          showToast('Removed from Watch Later');
        } else {
          wl.push(slug);
          showToast('Saved to Watch Later', 'View Playlist', '/watch-later');
        }

        localStorage.setItem('freeyt_watch_later', JSON.stringify(wl));
        window.dispatchEvent(new Event('watchLaterChanged'));
        updateWatchLaterButtons();
      });
    });

    renderProgressOnCards();
    updateWatchLaterButtons();
    window.addEventListener('watchLaterChanged', updateWatchLaterButtons);
  </script>
</Layout>
